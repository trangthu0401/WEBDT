@model List<WebBanDienThoai.Models.ViewModels.CustomerViewModel>
@{
    ViewData["Title"] = "Quản lý khách hàng";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    var page = (int)ViewBag.Page;
    var totalPages = (int)ViewBag.TotalPages;

    // === LOGIC PHÂN TRANG ===
    int maxPageLinks = 3; // Số lượng link trang tối đa hiển thị
    var startPage = Math.Max(1, page - (maxPageLinks / 2));
    var endPage = Math.Min(totalPages, startPage + maxPageLinks - 1);

    // Điều chỉnh lại startPage nếu endPage chạm mốc totalPages
    if (endPage == totalPages)
    {
        startPage = Math.Max(1, totalPages - maxPageLinks + 1);
    }
    // === KẾT THÚC LOGIC ===
}

<link href="~/css/searchStyle.css?v=3" rel="stylesheet" />

<div class="container mt-4">
    <div class="d-flex justify-content-between mb-3">
        <!-- Ô tìm kiếm -->
        <div class="w-50 custom-search-bar">
            <input type="text" id="searchBox" placeholder="Nhập ID, tên..."
                   value="@ViewBag.Search" aria-label="Search">

            <button type="button" onclick="filter()">
                <i class="bi bi-search"></i>
            </button>
        </div>

        <!-- Lọc loại -->
        <select id="typeFilter" class="form-select w-25" onchange="filter()">
            <option value="">--Loại khách hàng--</option>
            <option value="Thường" selected="@(ViewBag.TypeFilter == "Thường")">Thường</option>
            <option value="VIP" selected="@(ViewBag.TypeFilter == "VIP")">VIP</option>

        </select>
    </div>

    <!-- Bảng -->
    <table class="table align-middle text-center rounded-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>TÊN</th>
                <th>LOẠI</th>
                <th>GIỚI TÍNH</th>
                <th>HÀNH ĐỘNG</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var c in Model)
            {
                <tr class="@(c.IsActive ? "" : "tr-inactive")">
                    <td>@c.CustomerCode</td>
                    <td>@c.FullName</td>
                    <td>
                        @if (c.CustomerType == "VIP")
                        {
                            <span class="badge bg-danger-subtle text-danger rounded-pill px-3 py-2">VIP</span>
                        }
                        else
                        {
                            <span class="badge bg-success-subtle text-success rounded-pill px-3 py-2">Thường</span>
                        }
                    </td>
                    <td>@c.Gender</td>
                    <td>
                        <a href="~/Customer/Details/@c.CustomerID" class="btn-table-detail">
                            Chi tiết <i class="bi bi-arrow-right-short"></i>
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <!-- Phân trang -->
    <div class="d-flex justify-content-between align-items-center mt-3">
        <div>Trang @(page) / @totalPages</div>
        <nav>
            <ul class="pagination mb-0">
                <!-- Nút 'Trước' -->
                <li class="page-item @(page <= 1 ? "disabled" : "")">
                    <a class="page-link" href="@Url.Action("Index", new { searchId = ViewBag.SearchId, statusFilter = ViewBag.StatusFilter, startDate = ViewBag.StartDate, endDate = ViewBag.EndDate, page = page - 1 })">‹</a>
                </li>

                <!-- Hiển thị '1 ...' nếu cần (LOGIC MỚI) -->
                @if (startPage > 1)
                {
                    <li class="page-item">
                        <a class="page-link" href="@Url.Action("Index", new { searchId = ViewBag.SearchId, statusFilter = ViewBag.StatusFilter, startDate = ViewBag.StartDate, endDate = ViewBag.EndDate, page = 1 })">1</a>
                    </li>
                    @if (startPage > 2)
                    {
                        <!-- Chỉ hiển thị '...' nếu cách trang 1 ít nhất 1 số -->
                        <li class="page-item disabled"><span class="page-link">...</span></li>
                    }
                }

                <!-- Vòng lặp các trang chính (chỉ lặp 5 trang) -->
                @for (int i = startPage; i <= endPage; i++)
                {
                    <li class="page-item @(i == page ? "active" : "")">
                        <a class="page-link" href="@Url.Action("Index", new { searchId = ViewBag.SearchId, statusFilter = ViewBag.StatusFilter, startDate = ViewBag.StartDate, endDate = ViewBag.EndDate, page = i })">@i</a>
                    </li>
                }

                <!-- Hiển thị '... [cuối]' nếu cần (LOGIC MỚI) -->
                @if (endPage < totalPages)
                {
                    @if (endPage < totalPages - 1)
                    {
                        <!-- Chỉ hiển thị '...' nếu cách trang cuối ít nhất 1 số -->
                        <li class="page-item disabled"><span class="page-link">...</span></li>
                    }
                    <li class="page-item">
                        <a class="page-link" href="@Url.Action("Index", new { searchId = ViewBag.SearchId, statusFilter = ViewBag.StatusFilter, startDate = ViewBag.StartDate, endDate = ViewBag.EndDate, page = totalPages })">@totalPages</a>
                    </li>
                }

                <!-- Nút 'Sau' -->
                <li class="page-item @(page >= totalPages ? "disabled" : "")">
                    <a class="page-link" href="@Url.Action("Index", new { searchId = ViewBag.SearchId, statusFilter = ViewBag.StatusFilter, startDate = ViewBag.StartDate, endDate = ViewBag.EndDate, page = page + 1 })">›</a>
                </li>
            </ul>
        </nav>
    </div>
</div>

<script>
    function filter() {
        const search = document.getElementById("searchBox").value;
        const type = document.getElementById("typeFilter").value;
        window.location.href = `?search=${encodeURIComponent(search)}&typeFilter=${encodeURIComponent(type)}&page=1`;
    }
</script>
