@model WebBanDienThoai.Models.ViewModels.ProductDetailViewModel
@{
    ViewData["Title"] = Model.ProductDetail.Product.Name;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <style>
        /* === 1. CẤU TRÚC LAYOUT === */
        .product-section {
            padding-top: 20px;
            background-color: #fff;
        }

        .product-layout {
            display: grid;
            grid-template-columns: 42% 58%;
            gap: 40px;
            margin-top: 15px;
        }

        /* === 2. GALLERRY ẢNH === */
        .product-gallery {
            position: sticky;
            top: 90px;
            background: #fff;
            border-radius: 12px;
            padding: 15px;
            border: 1px solid #f0f0f0;
            text-align: center;
        }

        .product-image {
            max-width: 100%;
            height: auto;
            max-height: 450px;
            object-fit: contain;
        }

        /* === 3. THÔNG TIN CHI TIẾT === */
        .product-details {
            padding-right: 10px;
        }

        .product-main-title {
            font-size: 24px;
            font-weight: 700;
            color: #333;
            margin-bottom: 5px;
            line-height: 1.3;
        }

        /* Giá tiền */
        .price-card {
            background: #fafafa;
            border-radius: 8px;
            padding: 12px 15px;
            margin: 15px 0;
            display: flex;
            align-items: baseline;
            gap: 10px;
        }

        .price-amount {
            font-size: 28px;
            font-weight: 700;
            color: #d70018;
            margin: 0;
            line-height: 1;
        }

        .old-price {
            font-size: 14px;
            color: #777;
            text-decoration: line-through;
        }

        .discount-badge {
            background: #ffebee;
            color: #d70018;
            font-size: 11px;
            font-weight: 600;
            padding: 2px 6px;
            border-radius: 4px;
            margin-left: 5px;
        }

        /* Nhóm tùy chọn */
        .option-group {
            margin-bottom: 15px;
        }

        .option-title {
            font-size: 13px;
            font-weight: 600;
            color: #333;
            margin-bottom: 8px;
            text-transform: uppercase;
        }

        /* Nút chọn Phiên bản */
        .option-buttons {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
        }

        .option-btn {
            padding: 6px 15px;
            border: 1px solid #ddd;
            background: #fff;
            border-radius: 6px;
            font-size: 13px;
            font-weight: 500;
            color: #333;
            transition: 0.2s;
            text-align: center;
            min-width: 80px;
        }

            .option-btn:hover {
                border-color: #d70018;
            }

            .option-btn.active {
                border-color: #d70018;
                background: #fef2f2;
                color: #d70018;
                font-weight: 600;
                position: relative;
            }

                .option-btn.active::after {
                    content: '';
                    position: absolute;
                    top: 0;
                    right: 0;
                    border-top: 12px solid #d70018;
                    border-left: 12px solid transparent;
                    border-top-right-radius: 5px;
                }

        /* Grid Màu sắc */
        .color-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 8px;
        }

        .color-option {
            border: 1px solid #ddd;
            border-radius: 6px;
            padding: 8px;
            background: #fff;
            cursor: pointer;
            transition: 0.2s;
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
            height: 100%;
        }

            .color-option:hover {
                border-color: #d70018;
            }

            .color-option.active {
                border-color: #d70018;
                background: #fff;
                box-shadow: 0 0 0 1px #d70018 inset;
            }

        .color-name {
            font-size: 12px;
            font-weight: 600;
            margin-bottom: 2px;
            color: #333;
        }

        .color-price {
            font-size: 11px;
            color: #555;
        }

        /* Bộ chọn số lượng */
        .quantity-wrapper {
            display: flex;
            align-items: center;
            gap: 15px;
            margin: 20px 0;
            padding-top: 15px;
            border-top: 1px dashed #eee;
        }

        .qty-control {
            display: flex;
            border: 1px solid #ddd;
            border-radius: 4px;
            height: 32px;
        }

        .qty-btn {
            width: 30px;
            background: #f9f9f9;
            border: none;
            font-weight: bold;
            color: #333;
            cursor: pointer;
        }

            .qty-btn:hover {
                background: #eee;
            }

        .qty-input {
            width: 40px;
            text-align: center;
            border: none;
            border-left: 1px solid #ddd;
            border-right: 1px solid #ddd;
            font-size: 14px;
            font-weight: 600;
            outline: none;
        }

        /* Nút hành động */
        .action-buttons {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
            margin-top: 15px;
        }

        .btn-action {
            border: none;
            border-radius: 8px;
            padding: 10px;
            cursor: pointer;
            transition: 0.2s;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            line-height: 1.2;
            height: 54px;
        }

        .btn-buy {
            background: linear-gradient(180deg, #f00 0%, #d00 100%);
            color: white;
        }

            .btn-buy strong {
                font-size: 15px;
                text-transform: uppercase;
            }

            .btn-buy span {
                font-size: 11px;
                opacity: 0.9;
                font-weight: 400;
            }

            .btn-buy:hover {
                box-shadow: 0 4px 12px rgba(220,0,0,0.3);
            }

        .btn-add {
            background: #fff;
            border: 2px solid #d70018;
            color: #d70018;
        }

            .btn-add i {
                font-size: 20px;
                margin-bottom: 2px;
            }

            .btn-add span {
                font-size: 11px;
                font-weight: 600;
                text-transform: uppercase;
            }

            .btn-add:hover {
                background: #fff5f5;
            }

        /* === 4. BẢNG THÔNG SỐ === */
        .specs-section {
            background: #fff;
            border-radius: 12px;
            padding: 20px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.05);
            margin-top: 30px;
            border: 1px solid #f0f0f0;
        }

        .section-header {
            font-size: 18px;
            font-weight: 700;
            color: #333;
            margin-bottom: 15px;
            text-transform: uppercase;
        }

        .specs-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 14px;
        }

            .specs-table tr {
                border-bottom: 1px solid #eee;
            }

                .specs-table tr:last-child {
                    border-bottom: none;
                }

                .specs-table tr:nth-child(odd) {
                    background-color: #fff;
                }

                .specs-table tr:nth-child(even) {
                    background-color: #f9f9f9;
                }

            .specs-table td {
                padding: 10px 15px;
                vertical-align: top;
            }

        .spec-name {
            width: 35%;
            color: #666;
            font-weight: 500;
        }

        .spec-val {
            color: #333;
            font-weight: 500;
        }

        /* Responsive */
        media (max-width: 768px) {
            .product-layout

        {
            grid-template-columns: 1fr;
            gap: 20px;
        }

        .product-gallery {
            position: static;
            margin-bottom: 20px;
        }

        .color-grid {
            grid-template-columns: repeat(3, 1fr);
        }

        }
    </style>
}

<main id="section-product" class="product-section">
    <div class="container">
        <div style="font-size: 13px; color: #777; margin-bottom: 10px;">
            Trang chủ / @Model.ProductDetail.Product.Brand.BrandName / @Model.ProductDetail.Product.Name
        </div>

        <input type="hidden" id="currentVariantId" value="@Model.ProductDetail.VariantId" />

        <div class="product-layout">
            <div class="product-gallery">
                <img src="@(Model.ProductDetail.ImageUrl ?? Model.ProductDetail.Product.MainImage)"
                     alt="@Model.ProductDetail.Product.Name"
                     class="product-image">
            </div>

            <div class="product-details">
                <h1 class="product-main-title">
                    @Model.ProductDetail.Product.Name
                    <span style="font-weight: 400; font-size: 20px; color: #555;">
                        (@Model.ProductDetail.RAM - @Model.ProductDetail.Storage)
                    </span>
                </h1>

                <div class="price-card">
                    @{
                        var price = Model.ProductDetail.Price;
                        var discount = Model.ProductDetail.DiscountPrice;
                    }
                    @if (discount.HasValue && discount.Value < price)
                    {
                        <p class="price-amount">@discount.Value.ToString("N0")₫</p>
                        <span class="old-price">@price.ToString("N0")₫</span>
                        <span class="discount-badge">Giảm @((int)((1 - discount.Value / price) * 100))%</span>
                    }
                    else
                    {
                        <p class="price-amount">@price.ToString("N0")₫</p>
                    }
                </div>

                <div class="option-group">
                    <div class="option-title">Phiên bản</div>
                    <div class="option-buttons">
                        @{
                            var uniqueConfigs = Model.AllVariants
                            .GroupBy(v => new { v.RAM, v.Storage })
                            .Select(g => g.First())
                            .OrderBy(v => v.RAM);
                        }
                        @foreach (var variant in uniqueConfigs)
                        {
                            var isActive = (variant.RAM == Model.ProductDetail.RAM && variant.Storage == Model.ProductDetail.Storage) ? "active" : "";

                            <a asp-controller="Home" asp-action="ProductDetail" asp-route-id="@variant.VariantId"
                               class="option-btn @isActive">
                                @variant.RAM - @variant.Storage
                            </a>
                        }
                    </div>
                </div>

                <div class="option-group">
                    <div class="option-title">Màu sắc</div>
                    <div class="color-grid">
                        @{
                            var uniqueColors = Model.AllVariants
                            .GroupBy(v => v.Color)
                            .Select(g => g.First());
                        }
                        @foreach (var variant in uniqueColors)
                        {
                            var isActive = (variant.Color == Model.ProductDetail.Color) ? "active" : "";

                            // ĐÃ SỬA: Dùng variant.DiscountPrice (Nullable) và variant.Price (Non-nullable)
                            var displayPrice = (variant.DiscountPrice.HasValue && variant.DiscountPrice > 0)
                            ? variant.DiscountPrice.Value
                            : variant.Price;

                            <div class="color-option @isActive"
                                 onclick="location.href='@Url.Action("ProductDetail", new { id = variant.VariantId })'">
                                <span class="color-name">@variant.Color</span>
                                <span class="color-price">@displayPrice.ToString("N0")₫</span>
                            </div>
                        }
                    </div>
                </div>

                <div class="quantity-wrapper">
                    <span style="font-weight: 600; font-size: 14px; min-width: 80px;">Số lượng:</span>
                    <div class="qty-control">
                        <button class="qty-btn" onclick="adjustQty(-1)">-</button>
                        <input type="number" id="buyQuantity" value="1" min="1" class="qty-input" readonly />
                        <button class="qty-btn" onclick="adjustQty(1)">+</button>
                    </div>
                    <span style="font-size: 12px; color: #777;">
                        (Kho: @Model.ProductDetail.Stock)
                    </span>
                </div>

                <div class="action-buttons">
                    <button class="btn-action btn-buy" onclick="buyNow()">
                        <strong>Mua ngay</strong>
                        <span>(Giao tận nơi hoặc lấy tại cửa hàng)</span>
                    </button>
                    <button class="btn-action btn-add" onclick="addToCart()">
                        <i class="fas fa-cart-plus"></i>
                        <span>Thêm vào giỏ</span>
                    </button>
                </div>

                <div style="margin-top: 20px; background: #f8f9fa; padding: 10px; border-radius: 8px; font-size: 13px;">
                    <strong style="color: #d70018; display: block; margin-bottom: 5px;">
                        <i class="fas fa-gift"></i> Ưu đãi thêm:
                    </strong>
                    <ul style="margin: 0; padding-left: 20px; color: #555;">
                        <li>Giảm thêm 5% khi thanh toán qua VNPay</li>
                        <li>Tặng gói bảo hành vàng 12 tháng</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</main>

<section class="container">
    <div class="specs-section">
        <h2 class="section-header">Thông số kỹ thuật</h2>
        <table class="specs-table">
            <tbody>
                <tr>
                    <td class="spec-name">Màn hình</td>
                    <td class="spec-val">@Model.ProductDetail.Product.ScreenSize inches, @Model.ProductDetail.Product.ScreenTech</td>
                </tr>
                <tr>
                    <td class="spec-name">Camera sau</td>
                    <td class="spec-val">@Model.ProductDetail.Product.RearCamera</td>
                </tr>
                <tr>
                    <td class="spec-name">Camera trước</td>
                    <td class="spec-val">@Model.ProductDetail.Product.FrontCamera</td>
                </tr>
                <tr>
                    <td class="spec-name">Vi xử lý (Chipset)</td>
                    <td class="spec-val">@Model.ProductDetail.Product.Chipset</td>
                </tr>
                <tr>
                    <td class="spec-name">RAM</td>
                    <td class="spec-val">@Model.ProductDetail.RAM</td>
                </tr>
                <tr>
                    <td class="spec-name">Bộ nhớ trong</td>
                    <td class="spec-val">@Model.ProductDetail.Storage</td>
                </tr>
                <tr>
                    <td class="spec-name">Pin & Sạc</td>
                    <td class="spec-val">@Model.ProductDetail.Product.BatteryCapacity mAh</td>
                </tr>
                <tr>
                    <td class="spec-name">Hệ điều hành</td>
                    <td class="spec-val">@Model.ProductDetail.Product.OperatingSystem</td>
                </tr>
            </tbody>
        </table>
    </div>
</section>

<section class="container" style="margin-bottom: 40px;">
    <div class="specs-section">
        <h2 class="section-header">Đánh giá chi tiết</h2>
        <div class="product-description-content" style="line-height: 1.8; color: #444;">
            @Html.Raw(Model.ProductDetail.Product.Description)
        </div>
    </div>
</section>

<section id="section-related" class="container" style="margin-bottom: 60px;">
    <h2 class="section-header" style="border-left: 4px solid #d70018; padding-left: 10px; margin-bottom: 20px;">
        Sản phẩm tương tự
    </h2>
    @if (Model.RelatedProducts.Any())
    {
        <div class="row">
            @foreach (var variant in Model.RelatedProducts.Take(4))
            {
                <div class="col-md-3 col-6 mb-3">
                    <div class="product-card-list h-100" style="border:1px solid #eee; border-radius:8px; overflow:hidden;">
                        <div class="card-img-container" style="padding:15px; text-align:center;">
                            <a href="/Home/ProductDetail/@variant.VariantId">
                                <img src="@(variant.ImageUrl ?? variant.Product.MainImage)"
                                     style="height:160px; object-fit:contain;"
                                     alt="@variant.Product.Name">
                            </a>
                        </div>
                        <div class="product-info-list" style="padding:10px;">
                            <a href="/Home/ProductDetail/@variant.VariantId" style="font-weight:600; color:#333; display:block; margin-bottom:5px;">
                                @variant.Product.Name
                            </a>

                            @{
                                // ĐÃ SỬA: Xử lý Nullable Decimal cho phần Related Products
                                var finalPrice = (variant.DiscountPrice.HasValue && variant.DiscountPrice > 0)
                                ? variant.DiscountPrice.Value
                                : variant.Price;
                            }

                            <div style="color:#d70018; font-weight:700;">
                                @finalPrice.ToString("N0")₫
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</section>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        // 1. Tăng giảm số lượng
        function adjustQty(delta) {
            var input = document.getElementById('buyQuantity');
            var newVal = parseInt(input.value) + delta;
            var maxStock = @Model.ProductDetail.Stock;

            if (newVal >= 1 && newVal <= maxStock) {
                input.value = newVal;
            } else if (newVal > maxStock) {
                Swal.fire({ icon: 'info', title: 'Đã đạt giới hạn kho', text: 'Chỉ còn ' + maxStock + ' sản phẩm' });
            }
        }

        // 2. Thêm vào giỏ hàng
        function addToCart() {
            var vId = $('#currentVariantId').val();
            var qty = $('#buyQuantity').val();

            if (!vId) {
                Swal.fire('Lỗi', 'Sản phẩm không hợp lệ', 'error');
                return;
            }

            $.ajax({
                url: '/Cart/AddToCart',
                type: 'POST',
                data: { variantId: vId, quantity: qty },
                success: function (res) {
                    if (res.success) {
                        const Toast = Swal.mixin({
                            toast: true,
                            position: 'top-end',
                            showConfirmButton: false,
                            timer: 2000,
                            timerProgressBar: true
                        });
                        Toast.fire({ icon: 'success', title: 'Đã thêm vào giỏ hàng!' });

                        if (typeof updateCartCount === 'function') {
                            updateCartCount();
                        }
                    } else {
                        if (res.message && res.message.toLowerCase().includes("đăng nhập")) {
                            Swal.fire({
                                title: 'Chưa đăng nhập',
                                text: "Vui lòng đăng nhập để mua hàng",
                                icon: 'warning',
                                showCancelButton: true,
                                confirmButtonColor: '#d70018',
                                confirmButtonText: 'Đăng nhập ngay'
                            }).then((r) => {
                                if (r.isConfirmed) window.location.href = "/Account/Login";
                            });
                        } else {
                            Swal.fire('Thông báo', res.message, 'error');
                        }
                    }
                },
                error: function () {
                    Swal.fire('Lỗi', 'Lỗi kết nối server', 'error');
                }
            });
        }

        // 3. Mua ngay
        function buyNow() {
            var vId = $('#currentVariantId').val();
            var qty = $('#buyQuantity').val();

            $.ajax({
                url: '/Cart/AddToCart',
                type: 'POST',
                data: { variantId: vId, quantity: qty },
                success: function (res) {
                    if (res.success) {
                        window.location.href = "/Cart/Index";
                    } else {
                        if (res.message.toLowerCase().includes("đăng nhập")) {
                            window.location.href = "/Account/Login";
                        } else {
                            Swal.fire('Lỗi', res.message, 'error');
                        }
                    }
                }
            });
        }
    </script>
}