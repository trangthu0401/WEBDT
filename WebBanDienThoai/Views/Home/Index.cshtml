@model WebBanDienThoai.Models.modelView.ManageProductsViewModel

@{
    Layout = null;
    var currentSort = ViewData["CurrentSort"] as string;
    var currentSearch = ViewData["CurrentSearch"] as string;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home - Rabit Store</title>
    <link rel="stylesheet" href="~/css/home.css">
</head>
<body>
    <header class="site-header">
        <div class="header-top">
            <div class="container header-top-container">
                <a asp-controller="Home" asp-action="Index" class="logo">
                    <h1 class="logo-text">Rabit</h1>
                    <img src="~/images/linhvatcau.png" alt="Rabit Mascot" class="logo-mascot">
                    <h1 class="logo-text">Store</h1>
                </a>
                <form asp-controller="Home" asp-action="Index" method="get" class="search-form" id="mainSearchForm">
                    <input type="text" name="searchString" value="@currentSearch" placeholder="Tìm kiếm" class="search-input" id="mainSearchInput" autocomplete="off">
                    <button type="submit" class="search-button">
                        <img src="~/images/search.png" alt="Search Icon">
                    </button>
                    <input type="hidden" name="id" value="@Model.BrandId" />
                    <div class="search-suggestions" id="mainSearchSuggestions"></div>
                </form>
                <div class="header-actions">
                    <a href="#" class="cart-link">
                        <span>Giỏ hàng</span>
                        <img src="~/images/giohang.png" alt="Cart Icon">
                    </a>
                    <a href="#" class="user-profile">
                        <span>Trung</span>
                        <img src="~/images/user.png" alt="User Icon">
                    </a>
                </div>
            </div>
        </div>
        <nav class="main-nav">
            <div class="container nav-container">
                <a asp-controller="Home" asp-action="Index">Trang chủ</a>
                <a asp-controller="Home" asp-action="Favorites">Yêu thích</a>
                <a href="#" class="dropdown-link">
                    Danh mục
                    <img src="~/images/chevron-down.png" alt="Dropdown arrow">
                </a>
            </div>
        </nav>
    </header>

    <section id="hero" class="hero-section">
        <div class="container hero-container">
            <aside class="category-sidebar">
                <ul>
                    @if (Model.BrandCounts != null && Model.BrandCounts.Any())
                    {
                        <li class="@(Model.BrandId == null ? "active" : "")">
                            <a asp-controller="Home" asp-action="Index" asp-route-id="" asp-route-searchString="">
                                <span>Tất cả hãng</span>
                                <span class="badge">@Model.TotalProductCount</span>
                            </a>
                        </li>
                        @foreach (var brand in Model.BrandCounts)
                        {
                            <li class="@(Model.BrandId == brand.brandId ? "active" : "")">
                                <a asp-controller="Home" asp-action="Index" asp-route-id="@brand.brandId" asp-route-searchString="@currentSearch">
                                    <span>@brand.BrandName</span>
                                    <img src="~/images/next .png" alt="arrow">
                                </a>
                            </li>
                        }
                    }
                    else
                    {
                        <li><a href="#"><span>Chưa có danh mục</span></a></li>
                    }
                </ul>
            </aside>
            <div class="hero-carousel">
                <img src="https://cdn2.cellphones.com.vn/insecure/rs:fill:1036:450/q:90/plain/https://dashboard.cellphones.com.vn/storage/690x300_iPhone_17_Pro_Opensale_v3.png" alt="iPhone Air Banner" class="carousel-image">
                <button class="carousel-control prev">
                    <img src="~/images/muitenphai.png" alt="Previous">
                </button>
                <button class="carousel-control next">
                    <img src="~/images/muitenphai.png" alt="Next">
                </button>
            </div>
            <aside class="ads-sidebar">
                <a href="#" class="ad-banner">
                    <img src="~/images/poster1.png" alt="Watch Series Ad">
                </a>
                <a href="#" class="ad-banner">
                    <img src="~/images/poster2.png" alt="S25 Series Ad">
                </a>
            </aside>
        </div>
    </section>

    <section id="products" class="products-section">
        <div class="container">

            <div class="sort-buttons">
                <span>Sắp xếp theo:</span>
                <a asp-controller="Home" asp-action="Index" asp-route-id="@Model.BrandId" asp-route-sortOrder="" asp-route-searchString="@currentSearch"
                   class="sort-btn @(string.IsNullOrEmpty(currentSort) ? "active" : "")">
                    Mới nhất
                </a>
                <a asp-controller="Home" asp-action="Index" asp-route-id="@Model.BrandId" asp-route-sortOrder="price_asc" asp-route-searchString="@currentSearch"
                   class="sort-btn @(currentSort == "price_asc" ? "active" : "")">
                    Giá thấp -> cao
                </a>
                <a asp-controller="Home" asp-action="Index" asp-route-id="@Model.BrandId" asp-route-sortOrder="price_desc" asp-route-searchString="@currentSearch"
                   class="sort-btn @(currentSort == "price_desc" ? "active" : "")">
                    Giá cao -> thấp
                </a>
            </div>

            <div class="product-grid">
                @if (Model.Products != null && Model.Products.Any())
                {
                    @foreach (var product in Model.Products)
                    {
                        <a asp-controller="Home" asp-action="ProductDetail" asp-route-id="@product.FirstVariantId" class="product-card">
                            <img src="@(string.IsNullOrEmpty(product.MainImage) ? "~/images/default-product.png" : product.MainImage)"
                                 alt="@product.Name" class="product-image">

                            <div class="product-info">
                                <h3 class="product-name">@product.Name</h3>
                                <p class="product-price">@product.Price.ToString("N0")đ</p>

                                @if (product.IsFavorited)
                                {
                                    <button class="wishlist-button liked" data-productid="@product.ProductId">
                                        <img src="~/images/tym.png" alt="Wishlist heart">
                                        <span>Đã thích</span>
                                    </button>
                                }
                                else
                                {
                                    <button class="wishlist-button" data-productid="@product.ProductId">
                                        <img src="~/images/tym.png" alt="Wishlist heart">
                                        <span>Yêu thích</span>
                                    </button>
                                }
                            </div>
                        </a>
                    }
                }
                else
                {
                    <p>Không tìm thấy sản phẩm nào phù hợp.</p>
                }
            </div>
        </div>

        <button class="fab-contact" id="fabChatButton">
            <span>Liên hệ & AI</span>
            <img src="~/images/lienhe.png" alt="Contact Icon">
        </button>
        <div class="chat-window" id="chatWindow">
            <div class="chat-header">
                <span>Rabit AI & Liên hệ</span>
                <button class="chat-close" id="chatCloseButton">&times;</button>
            </div>
            <div class="chat-body" id="chatBody">
                <div class="chat-message bot-message">
                    <p>Xin chào! Bạn muốn tôi gợi ý điện thoại (ví dụ: 'iphone') hay muốn liên hệ trực tiếp (ví dụ: 'zalo', 'sđt')?</p>
                </div>
            </div>
            <div class="chat-input-area">
                <input type="text" id="chatInput" placeholder="Nhập tin nhắn...">
                <button id="chatSendButton">Gửi</button>
            </div>
            <div class="contact-links-bar">
                <a href="https://zalo.me/0999999999" target="_blank">
                    <img src="~/images/zalo-icon.png" alt="Zalo"> Zalo
                </a>
                <a href="tel:0999999999">
                    <img src="~/images/phone-icon.png" alt="Phone"> Gọi điện
                </a>
            </div>
        </div>

    </section>

    <script>
        document.addEventListener('DOMContentLoaded', function() {

            // --- SỬA CODE NÚT YÊU THÍCH (Thêm stopPropagation) ---
            const wishlistButtons = document.querySelectorAll('.wishlist-button');
            wishlistButtons.forEach(button => {
                button.addEventListener('click', function(e) {
                    e.preventDefault(); // Ngăn thẻ <a> cha bị click
                    e.stopPropagation(); // Ngăn thẻ <a> cha bị click

                    const productId = this.dataset.productid;
                    const buttonElement = this;
                    const isFavorited = buttonElement.classList.contains('liked');
                    const url = isFavorited ? '/Home/RemoveFromFavorites/' + productId : '/Home/AddToFavorites/' + productId;

                    fetch(url, { method: 'POST' })
                    .then(response => response.json())
                    .then(data => {
                        if(data.success) {
                            if(isFavorited) {
                                buttonElement.classList.remove('liked');
                                buttonElement.innerHTML = '<img src="/images/tym.png" alt="Wishlist heart"> <span>Yêu thích</span>';
                            } else {
                                buttonElement.classList.add('liked');
                                buttonElement.innerHTML = '<img src="/images/tym.png" alt="Wishlist heart"> <span>Đã thích</span>';
                            }
                        } else { alert(data.message); }
                    })
                    .catch(error => console.error('Error:', error));
                });
            });

            // --- (Code Chatbot và Tìm kiếm giữ nguyên) ---
            const fabChatButton = document.getElementById('fabChatButton');
            const chatWindow = document.getElementById('chatWindow');
            const chatCloseButton = document.getElementById('chatCloseButton');
            const chatBody = document.getElementById('chatBody');
            const chatInput = document.getElementById('chatInput');
            const chatSendButton = document.getElementById('chatSendButton');
            fabChatButton.addEventListener('click', () => { chatWindow.classList.toggle('active'); });
            chatCloseButton.addEventListener('click', () => { chatWindow.classList.remove('active'); });
            chatSendButton.addEventListener('click', handleUserMessage);
            chatInput.addEventListener('keydown', function(e) { if (e.key === 'Enter') { handleUserMessage(); } });
            function handleUserMessage() {
                const userInput = chatInput.value.trim();
                if (userInput === "") return;
                appendMessage(userInput, 'user-message');
                chatInput.value = "";
                appendMessage("...", 'bot-message loading');
                fetch('/Home/GetAiResponse', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ message: userInput })
                })
                .then(response => response.json())
                .then(data => {
                    const loadingMessage = chatBody.querySelector('.loading');
                    if (loadingMessage) loadingMessage.remove();
                    appendMessage(data.message, 'bot-message');
                })
                .catch(error => {
                    console.error('Error:', error);
                    const loadingMessage = chatBody.querySelector('.loading');
                    if (loadingMessage) loadingMessage.remove();
                    appendMessage("Xin lỗi, tôi gặp lỗi kết nối.", 'bot-message');
                });
            }
            function appendMessage(text, className) {
                const messageDiv = document.createElement('div');
                messageDiv.classList.add('chat-message', ...className.split(' '));
                messageDiv.innerHTML = `<p>${text}</p>`;
                chatBody.appendChild(messageDiv);
                chatBody.scrollTop = chatBody.scrollHeight;
            }

            const searchInput = document.getElementById('mainSearchInput');
            const suggestionsContainer = document.getElementById('mainSearchSuggestions');
            const searchForm = document.getElementById('mainSearchForm');
            if (searchInput) {
                searchInput.addEventListener('keyup', function() {
                    const term = this.value;
                    if (term.length < 2) {
                        suggestionsContainer.innerHTML = '';
                        suggestionsContainer.style.display = 'none';
                        return;
                    }
                    fetch('/Home/SearchSuggestions?term=' + term)
                        .then(response => response.json())
                        .then(data => {
                            suggestionsContainer.innerHTML = '';
                            if (data.length > 0) {
                                suggestionsContainer.style.display = 'block';
                                const header = document.createElement('div');
                                header.classList.add('suggestion-header');
                                header.textContent = 'Sản phẩm gợi ý';
                                suggestionsContainer.appendChild(header);
                                data.forEach(product => {
                                    const suggestionLink = document.createElement('a');
                                    suggestionLink.classList.add('suggestion-item');
                                    suggestionLink.href = `/Home/Index?searchString=${encodeURIComponent(product.name)}`;
                                    const img = document.createElement('img');
                                    let imageUrl = product.mainImage;
                                    if (imageUrl && !imageUrl.startsWith('http')) {
                                        imageUrl = imageUrl.replace("~", "");
                                    }
                                    img.src = imageUrl ? imageUrl : '/images/default-product.png';
                                    img.alt = product.name;
                                    const infoDiv = document.createElement('div');
                                    infoDiv.classList.add('suggestion-item-info');
                                    const nameDiv = document.createElement('div');
                                    nameDiv.classList.add('suggestion-item-name');
                                    nameDiv.textContent = product.name;
                                    const priceDiv = document.createElement('div');
                                    priceDiv.classList.add('suggestion-item-price');
                                    priceDiv.textContent = product.price.toLocaleString('vi-VN', { style: 'currency', currency: 'VND' });
                                    infoDiv.appendChild(nameDiv);
                                    infoDiv.appendChild(priceDiv);
                                    suggestionLink.appendChild(img);
                                    suggestionLink.appendChild(infoDiv);
                                    suggestionLink.addEventListener('click', function(e) {
                                        e.preventDefault();
                                        searchInput.value = product.name;
                                        searchForm.submit();
                                    });
                                    suggestionsContainer.appendChild(suggestionLink);
                                });
                            } else {
                                suggestionsContainer.style.display = 'none';
                            }
                        });
                });
                document.addEventListener('click', function(e) {
                    if (!searchForm.contains(e.target)) {
                        suggestionsContainer.style.display = 'none';
                    }
                });
            }
        });
    </script>
</body>
</html>