@model WebBanDienThoai.Models.ViewModels.ManageProductsViewModel
@using System.Security.Claims

@{
    Layout = null;
    var currentSort = ViewData["CurrentSort"] as string;
    var currentSearch = ViewData["CurrentSearch"] as string;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Rabit Store - Điện thoại chính hãng giá tốt</title>
    <link rel="stylesheet" href="~/css/home.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
</head>
<body>
    <!-- HEADER -->
    <header class="site-header">
        <div class="header-top">
            <div class="container header-top-container">
                <a asp-controller="Home" asp-action="Index" class="logo">
                    <h1 class="logo-text">Rabit</h1>
                    <img src="~/images/linhvatcau.png" alt="Rabit Store" class="logo-mascot">
                    <h1 class="logo-text">Store</h1>
                </a>

                <form asp-controller="Home" asp-action="Index" method="get" class="search-form" id="mainSearchForm">
                    <input type="text" name="searchString" value="@currentSearch" placeholder="Tìm kiếm điện thoại, phụ kiện..." class="search-input" id="mainSearchInput" autocomplete="off">
                    <button type="submit" class="search-button">
                        <img src="~/images/search.png" alt="Search">
                    </button>
                    <input type="hidden" name="id" value="@Model.BrandId" />
                </form>

                <div class="header-actions">
                    <a href="~/Cart/Index" class="cart-link">
                        <img src="~/images/giohang.png" alt="Giỏ hàng">
                        <span>Giỏ hàng</span>
                        <span class="cart-count">0</span>
                    </a>

                    @if (User.Identity.IsAuthenticated)
                    {
                        <div class="user-profile-dropdown">
                            <a href="#" class="user-profile">
                                <img src="~/images/user.png" alt="Tài khoản">
                                <span>@User.FindFirstValue("FullName")</span>
                            </a>
                        </div>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Login" class="user-profile">
                            <img src="~/images/user.png" alt="Đăng nhập">
                            <span>Đăng nhập</span>
                        </a>
                    }
                </div>
            </div>
        </div>

        <nav class="main-nav">
            <div class="container nav-container">
                <a asp-controller="Home" asp-action="Index"><i class="fas fa-home"></i> Trang chủ</a>
                <a asp-controller="Home" asp-action="Favorites"><i class="fas fa-heart"></i> Yêu thích</a>
                <a href="#"><i class="fas fa-gift"></i> Khuyến mãi</a>
                <a href="#"><i class="fas fa-headset"></i> Hỗ trợ</a>
            </div>
        </nav>
    </header>

    <!-- HERO SECTION -->
    <section id="hero" class="hero-section">
        <div class="container hero-container">
            <aside class="category-sidebar">
                <ul>
                    <li class="@(Model.BrandId == null ? "active" : "")">
                        <a asp-action="Index" asp-route-id="">
                            <span>Tất cả sản phẩm</span>
                            <span class="badge">@Model.TotalProductCount</span>
                        </a>
                    </li>
                    @if (Model.BrandCounts != null)
                    {
                        foreach (var brand in Model.BrandCounts)
                        {
                            <li class="@(Model.BrandId == brand.BrandId ? "active" : "")">
                                <a asp-action="Index" asp-route-id="@brand.BrandId">
                                    <span>@brand.BrandName</span>
                                    <img src="~/images/next .png" alt=">">
                                </a>
                            </li>
                        }
                    }
                </ul>
            </aside>

            <div class="hero-carousel" id="heroCarousel">
                <div class="carousel-track">
                    <div class="carousel-slide">
                        <img src="https://cdn2.cellphones.com.vn/insecure/rs:fill:1036:450/q:90/plain/https://dashboard.cellphones.com.vn/storage/690x300_iPhone_17_Pro_Opensale_v3.png"
                             alt="iPhone 17 Pro" class="carousel-image">
                    </div>
                    <div class="carousel-slide">
                        <img src="https://cdn.tgdd.vn/Products/Images/42/329149/Slider/vi-vn-iphone-16-pro-max-1.jpg"
                             alt="iPhone 16 Pro Max" class="carousel-image">
                    </div>
                </div>
                <button class="carousel-control next" id="carouselNext">
                    <img src="~/images/muitenphai.png alt="Next">
                </button>
                <button class="carousel-control prev" id="carouselPrev">
                    <img src="~/images/muitentrai.png" style="transform:rotate(180deg)" alt="Previous">
                </button>
                
            </div>

            <aside class="ads-sidebar">
                <a href="#" class="ad-banner">
                    <img src="~/images/poster1.png" alt="Khuyến mãi đặc biệt">
                </a>
                <a href="#" class="ad-banner">
                    <img src="~/images/poster2.png" alt="Bảo hành 2 năm">
                </a>
            </aside>
        </div>
    </section>

    <!-- TOP BAN CHAY SECTION -->
    @if (Model.TopSellingProducts.Count > 0)
    {
        <section class="top-selling-section">
            <div class="container">
                <div class="section-header">
                    <h2 class="section-title">TOP BAN CHAY TUAN NAY</h2>
                    <a href="#" class="view-all-link">
                        Xem tất cả <i class="fas fa-arrow-right"></i>
                    </a>
                </div>

                <div class="product-grid">
                    @foreach (var product in Model.TopSellingProducts)
                    {
                        <div class="product-card @(product.FirstVariantId == 0 ? "disabled" : "")"
                             onclick="@(product.FirstVariantId > 0 ? $"location.href='/Home/ProductDetail/{product.FirstVariantId}'" : "")">

                            <div class="best-seller-badge">
                                <i class="fas fa-crown"></i> BAN CHAY
                            </div>

                            @if (product.FirstVariantId == 0)
                            {
                                <span class="out-of-stock-badge">HET HANG</span>
                            }

                            <div class="image-wrapper">
                                <img src="@(string.IsNullOrEmpty(product.MainImage) ? "/images/default-product.png" : product.MainImage)"
                                     alt="@product.Name" class="product-image">
                            </div>

                            <div class="product-info">
                                <h3 class="product-name" title="@product.Name">@product.Name</h3>

                                @if (product.FirstVariantId > 0)
                                {
                                    <p class="product-price">@product.Price.ToString("N0")₫</p>
                                    <p class="sold-count">
                                        <i class="fas fa-fire"></i> Da ban: @product.SoldCount
                                    </p>
                                }
                                else
                                {
                                    <p class="product-price" style="color:#999">LIEN HE</p>
                                }

                                <div class="wishlist-button @(product.IsFavorited ? "liked" : "")"
                                     data-productid="@product.ProductId" onclick="event.stopPropagation();">
                                    <i class="fa fa-heart"></i>
                                    <span>@(product.IsFavorited ? "Da thich" : "Yeu thich")</span>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </section>
    }

    <!-- ALL PRODUCTS SECTION -->
    <section id="products" class="products-section">
        <div class="container">
            <div class="section-header">
                <h2 class="section-title">TAT CA SAN PHAM</h2>
                <span class="product-count">@Model.TotalProductCount san pham</span>
            </div>

            <div class="sort-buttons">
                <span>Sap xep theo:</span>
                <a asp-action="Index" asp-route-id="@Model.BrandId" asp-route-sortOrder=""
                   class="sort-btn @(string.IsNullOrEmpty(currentSort) ? "active" : "")">
                    <i class="fas fa-star"></i> Moi nhat
                </a>
                <a asp-action="Index" asp-route-id="@Model.BrandId" asp-route-sortOrder="price_asc"
                   class="sort-btn @(currentSort == "price_asc" ? "active" : "")">
                    <i class="fas fa-sort-amount-up"></i> Gia tang
                </a>
                <a asp-action="Index" asp-route-id="@Model.BrandId" asp-route-sortOrder="price_desc"
                   class="sort-btn @(currentSort == "price_desc" ? "active" : "")">
                    <i class="fas fa-sort-amount-down"></i> Gia giam
                </a>
                <button id="filterButton" class="sort-btn">
                    <i class="fas fa-filter"></i> Bo loc nang cao
                </button>
            </div>

            <div class="product-grid">
                @if (Model.Products.Count > 0)
                {
                    foreach (var product in Model.Products)
                    {
                        <div class="product-card @(product.FirstVariantId == 0 ? "disabled" : "")"
                             onclick="@(product.FirstVariantId > 0 ? $"location.href='/Home/ProductDetail/{product.FirstVariantId}'" : "")">

                            @if (product.FirstVariantId == 0)
                            {
                                <span class="out-of-stock-badge">HET HANG</span>
                            }

                            <div class="image-wrapper">
                                <img src="@(string.IsNullOrEmpty(product.MainImage) ? "/images/default-product.png" : product.MainImage)"
                                     alt="@product.Name" class="product-image">
                            </div>

                            <div class="product-info">
                                <h3 class="product-name" title="@product.Name">@product.Name</h3>

                                @if (product.FirstVariantId > 0)
                                {
                                    <p class="product-price">@product.Price.ToString("N0")₫</p>
                                }
                                else
                                {
                                    <p class="product-price" style="color:#999">LIEN HE</p>
                                }

                                <div class="wishlist-button @(product.IsFavorited ? "liked" : "")"
                                     data-productid="@product.ProductId" onclick="event.stopPropagation();">
                                    <i class="fa fa-heart"></i>
                                    <span>@(product.IsFavorited ? "Da thich" : "Yeu thich")</span>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div style="grid-column:1/-1; text-align:center; padding:60px 20px;">
                        <i class="fas fa-search" style="font-size:48px; color:#ddd; margin-bottom:20px;"></i>
                        <h3 style="color:#999; margin-bottom:10px;">Khong tim thay san pham nao</h3>
                        <p style="color:#aaa;">Hay thu tim kiem voi tu khoa khac hoac danh muc khac</p>
                    </div>
                }
            </div>
        </div>
    </section>

    <!-- FLOATING ACTION BUTTONS -->
    <button class="fab-contact" id="fabChatButton">
        <img src="~/images/lienhe.png" alt="Hỗ trợ">
        <span>Ho tro 24/7</span>
    </button>

    <!-- FILTER POPUP -->
    <div class="filter-popup-overlay" id="filterPopup">
        <div class="filter-popup-content">
            <div class="filter-header">
                <h3><i class="fas fa-filter"></i> Bo loc san pham</h3>
                <span class="close-filter" id="closeFilter">&times;</span>
            </div>
            <form asp-action="Index" method="get">
                <input type="hidden" name="id" value="@Model.BrandId" />
                <div class="filter-group">
                    <label>Khoang gia</label>
                    <div class="price-range-inputs">
                        <input type="number" name="minPrice" placeholder="Tu" value="@Model.MinPrice">
                        <span>-</span>
                        <input type="number" name="maxPrice" placeholder="Den" value="@Model.MaxPrice">
                    </div>
                </div>
                <button type="submit" class="btn-apply-filter">
                    <i class="fas fa-check"></i> Ap dung bo loc
                </button>
            </form>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Wishlist Logic
            document.querySelectorAll('.wishlist-button').forEach(btn => {
                btn.addEventListener('click', function(e) {
                    e.stopPropagation();
                    e.preventDefault();

                    const pid = this.dataset.productid;
                    const isLiked = this.classList.contains('liked');
                    const url = isLiked ? `/Home/RemoveFromFavorites/${pid}` : `/Home/AddToFavorites/${pid}`;

                    // Add loading animation
                    this.style.opacity = '0.7';
                    const originalText = this.querySelector('span').innerText;
                    this.querySelector('span').innerText = 'Dang xu ly...';

                    fetch(url, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                        }
                    })
                    .then(r => r.json())
                    .then(d => {
                        if(d.success) {
                            this.classList.toggle('liked');
                            this.querySelector('span').innerText = isLiked ? 'Yeu thich' : 'Da thich';

                            // Heart animation
                            const heart = this.querySelector('i');
                            heart.style.transform = 'scale(1.5)';
                            setTimeout(() => {
                                heart.style.transform = 'scale(1)';
                            }, 300);
                        } else {
                            alert(d.message);
                            this.querySelector('span').innerText = originalText;
                        }
                        this.style.opacity = '1';
                    })
                    .catch(() => {
                        this.style.opacity = '1';
                        this.querySelector('span').innerText = originalText;
                        alert('Co loi xay ra, vui long thu lai!');
                    });
                });
            });

            // Enhanced Carousel Logic
            const track = document.querySelector('.carousel-track');
            if(track) {
                let idx = 0;
                const slides = track.children;
                const totalSlides = slides.length;

                const move = (i) => {
                    if(i >= totalSlides) i = 0;
                    if(i < 0) i = totalSlides - 1;
                    track.style.transform = `translateX(-${i * 100}%)`;
                    idx = i;
                }

                document.getElementById('carouselNext')?.addEventListener('click', () => move(idx + 1));
                document.getElementById('carouselPrev')?.addEventListener('click', () => move(idx - 1));

                // Auto slide every 5 seconds
                setInterval(() => move(idx + 1), 5000);
            }

            // Popup Logic
            const filterPopup = document.getElementById('filterPopup');
            document.getElementById('filterButton')?.addEventListener('click', () => {
                filterPopup.classList.add('active');
                document.body.style.overflow = 'hidden';
            });

            document.getElementById('closeFilter')?.addEventListener('click', () => {
                filterPopup.classList.remove('active');
                document.body.style.overflow = 'auto';
            });

            // Close popup when clicking outside
            filterPopup.addEventListener('click', (e) => {
                if(e.target === filterPopup) {
                    filterPopup.classList.remove('active');
                    document.body.style.overflow = 'auto';
                }
            });

            // Smooth scroll for anchor links
            document.querySelectorAll('a[href^="#"]').forEach(anchor => {
                anchor.addEventListener('click', function (e) {
                    e.preventDefault();
                    const target = document.querySelector(this.getAttribute('href'));
                    if(target) {
                        target.scrollIntoView({
                            behavior: 'smooth',
                            block: 'start'
                        });
                    }
                });
            });

            // Add loading animation to product cards
            const productCards = document.querySelectorAll('.product-card');
            productCards.forEach((card, index) => {
                card.style.animationDelay = `${index * 0.1}s`;
            });
        });

        // Add some interactive effects
        window.addEventListener('scroll', function() {
            const header = document.querySelector('.site-header');
            if(window.scrollY > 100) {
                header.style.background = 'rgba(255,255,255,0.95)';
                header.style.backdropFilter = 'blur(20px)';
            } else {
                header.style.background = 'var(--primary-light)';
                header.style.backdropFilter = 'blur(10px)';
            }
        });
    </script>
</body>
</html>