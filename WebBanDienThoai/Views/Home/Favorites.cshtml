@model WebBanDienThoai.Models.modelView.FavoritesViewModel

@{
    Layout = null;
    var currentSort = ViewData["CurrentSort"] as string;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sản phẩm Yêu thích - Rabit Store</title>
    <link rel="stylesheet" href="~/css/home.css">
</head>
<body>
    <header class="site-header">
        <div class="header-top">
            <div class="container header-top-container">
                <a asp-controller="Home" asp-action="Index" class="logo">
                    <h1 class="logo-text">Rabit</h1>
                    <img src="~/images/linhvatcau.png" alt="Rabit Mascot" class="logo-mascot">
                    <h1 class="logo-text">Store</h1>
                </a>
                <form class="search-form">
                    <input type="text" placeholder="Tìm kiếm" class="search-input">
                    <button type="submit" class="search-button">
                        <img src="~/images/search.png" alt="Search Icon">
                    </button>
                </form>
                <div class="header-actions">
                    <a href="#" class="cart-link">
                        <span>Giỏ hàng</span>
                        <img src="~/images/giohang.png" alt="Cart Icon">
                    </a>
                    <a href="#" class="user-profile">
                        <span>Trung</span>
                        <img src="~/images/user.png" alt="User Icon">
                    </a>
                </div>
            </div>
        </div>
        <nav class="main-nav">
            <div class="container nav-container">
                <a asp-controller="Home" asp-action="Index">Trang chủ</a>
                <a asp-controller="Home" asp-action="Favorites">Yêu thích</a>
                <a href="#" class="dropdown-link">
                    Danh mục
                    <img src="~/images/chevron-down.png" alt="Dropdown arrow">
                </a>
            </div>
        </nav>
    </header>

    <section id="products" class="products-section">
        <div class="container">

            <h2 style="text-align: center; margin-bottom: 30px; font-size: 2.5rem; color: var(--primary-red);">
                Sản phẩm Yêu thích của bạn
            </h2>

            <div class="sort-buttons">
                <span>Sắp xếp theo:</span>
                <a asp-controller="Home" asp-action="Favorites" asp-route-sortOrder=""
                   class="sort-btn @(string.IsNullOrEmpty(currentSort) ? "active" : "")">
                    Mới nhất
                </a>
                <a asp-controller="Home" asp-action="Favorites" asp-route-sortOrder="price_asc"
                   class="sort-btn @(currentSort == "price_asc" ? "active" : "")">
                    Giá thấp -> cao
                </a>
                <a asp-controller="Home" asp-action="Favorites" asp-route-sortOrder="price_desc"
                   class="sort-btn @(currentSort == "price_desc" ? "active" : "")">
                    Giá cao -> thấp
                </a>
            </div>

            <div class="product-grid">
                @if (Model.FavoriteProducts != null && Model.FavoriteProducts.Any())
                {
                    @foreach (var product in Model.FavoriteProducts)
                    {
                        <article class="product-card" id="product-card-@product.ProductId">
                            <img src="@(string.IsNullOrEmpty(product.MainImage) ? "~/images/default-product.png" : product.MainImage)"
                                 alt="@product.Name" class="product-image">

                            <div class="product-info">
                                <h3 class="product-name">@product.Name</h3>
                                <p class="product-price">@product.Price.ToString("N0")đ</p>

                                <button class="wishlist-button remove-favorite-button" data-productid="@product.ProductId">
                                    <span>➖ Xóa</span>
                                </button>
                            </div>
                        </article>
                    }
                }
                else
                {
                    <p style="text-align: center; font-size: 1.2rem; width: 100%;" id="empty-favorites-message">
                        Bạn chưa có sản phẩm yêu thích nào.
                    </p>
                }
            </div>
        </div>

        <button class="fab-contact" id="fabContactButton">
            <span>Liên hệ</span>
            <img src="~/images/lienhe.png" alt="Contact Icon">
        </button>

        <div class="contact-popup" id="contactPopup">
            <div class="contact-option">
                <a href="https://zalo.me/0999999999" target="_blank">
                    <img src="~/images/zalo-icon.png" alt="Zalo">
                    <span>Zalo: 0999999999</span>
                </a>
            </div>
            <div class="contact-option">
                <a href="tel:0999999999">
                    <img src="~/images/phone-icon.png" alt="Phone">
                    <span>Call: 0999999999</span>
                </a>
            </div>
        </div>
    </section>

    <script>
        document.addEventListener('DOMContentLoaded', function() {

            // --- CODE XỬ LÝ NÚT XÓA YÊU THÍCH (Giữ nguyên) ---
            const removeButtons = document.querySelectorAll('.remove-favorite-button');
            removeButtons.forEach(button => {
                button.addEventListener('click', function(e) {
                    e.preventDefault();
                    const productId = this.dataset.productid;
                    const buttonElement = this;
                    const cardElement = buttonElement.closest('.product-card');

                    fetch('/Home/RemoveFromFavorites/' + productId, { method: 'POST' })
                    .then(response => response.json())
                    .then(data => {
                        if(data.success) {
                            if (cardElement) cardElement.remove();
                            const remainingCards = document.querySelectorAll('.product-card');
                            if (remainingCards.length === 0) {
                                const msg = document.getElementById('empty-favorites-message');
                                if(msg) msg.style.display = 'block';
                            }
                        } else {
                            alert(data.message);
                        }
                    })
                    .catch(error => console.error('Error:', error));
                });
            });

            // --- THÊM JAVASCRIPT CHO POPUP LIÊN HỆ ---
            const fabContactButton = document.getElementById('fabContactButton');
            const contactPopup = document.getElementById('contactPopup');

            fabContactButton.addEventListener('click', function(e) {
                e.preventDefault();
                contactPopup.classList.toggle('active');
            });

            document.addEventListener('click', function(e) {
                if (fabContactButton.contains(e.target) || contactPopup.contains(e.target)) {
                    return;
                }
                contactPopup.classList.remove('active');
            });

        });
    </script>
</body>
</html>