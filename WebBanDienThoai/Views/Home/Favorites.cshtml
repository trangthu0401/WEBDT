@model WebBanDienThoai.Models.ViewModels.FavoritesViewModel
@using System.Security.Claims

@{
    Layout = null;
    var currentSort = ViewData["CurrentSort"] as string;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sản phẩm Yêu thích - Rabit Store</title>
    <link rel="stylesheet" href="~/css/home.css">
</head>
<body>
    <!-- HEADER (SỬ DỤNG PARTIAL VIEW) -->
    @await Html.PartialAsync("_Header")

    <section id="products" class="products-section">
        <div class="container">

            <h2 style="text-align: center; margin-bottom: 30px; font-size: 2.5rem; color: var(--primary-red);">
                Sản phẩm Yêu thích của bạn
            </h2>

            <div class="sort-buttons">
                <span>Sắp xếp theo:</span>
                <a asp-controller="Home" asp-action="Favorites" asp-route-sortOrder=""
                   class="sort-btn @(string.IsNullOrEmpty(currentSort) ? "active" : "")">
                    Mới nhất
                </a>
                <a asp-controller="Home" asp-action="Favorites" asp-route-sortOrder="price_asc"
                   class="sort-btn @(currentSort == "price_asc" ? "active" : "")">
                    Giá thấp -> cao
                </a>
                <a asp-controller="Home" asp-action="Favorites" asp-route-sortOrder="price_desc"
                   class="sort-btn @(currentSort == "price_desc" ? "active" : "")">
                    Giá cao -> thấp
                </a>
            </div>

            <div class="product-grid">
                @if (Model.FavoriteProducts != null && Model.FavoriteProducts.Any())
                {
                    @foreach (var product in Model.FavoriteProducts)
                    {
                        <article class="product-card" id="product-card-@product.ProductId">
                            <img src="@(string.IsNullOrEmpty(product.MainImage) ? "~/images/default-product.png" : product.MainImage)"
                                 alt="@product.Name" class="product-image">

                            <div class="product-info">
                                <h3 class="product-name">@product.Name</h3>
                                <p class="product-price">@product.Price.ToString("N0")đ</p>

                                <button class="wishlist-button remove-favorite-button" data-productid="@product.ProductId">
                                    <span>➖ Xóa</span>
                                </button>
                            </div>
                        </article>
                    }
                }
                else
                {
                    <p style="text-align: center; font-size: 1.2rem; width: 100%;" id="empty-favorites-message">
                        Bạn chưa có sản phẩm yêu thích nào.
                    </p>
                }
            </div>
        </div>

    </section>

    <script>
        document.addEventListener('DOMContentLoaded', function() {

            // --- CODE XỬ LÝ NÚT XÓA YÊU THÍCH ---
            const removeButtons = document.querySelectorAll('.remove-favorite-button');
            removeButtons.forEach(button => {
                button.addEventListener('click', function(e) {
                    e.preventDefault();
                    const productId = this.dataset.productid;
                    const buttonElement = this;
                    const cardElement = buttonElement.closest('.product-card');

                    fetch('/Home/RemoveFromFavorites/' + productId, { method: 'POST' })
                        .then(response => response.json())
                        .then(data => {
                            if(data.success) {
                                if (cardElement) cardElement.remove();
                                const remainingCards = document.querySelectorAll('.product-card');
                                if (remainingCards.length === 0) {
                                    const msg = document.getElementById('empty-favorites-message');
                                    if(msg) msg.style.display = 'block';
                                }
                            } else {
                                alert(data.message);
                            }
                        })
                        .catch(error => console.error('Error:', error));
                });
            });

            // === CODE CHO POPUP DANH MỤC ===
            const categoryDropdown = document.getElementById('categoryDropdown');
            const categoryToggle = document.getElementById('categoryDropdownToggle');
            if (categoryToggle) {
                categoryToggle.addEventListener('click', function(e) {
                    e.preventDefault();
                    categoryDropdown.classList.toggle('active');
                });
            }
            document.addEventListener('click', function(e) {
                if (categoryDropdown && !categoryDropdown.contains(e.target)) {
                    categoryDropdown.classList.remove('active');
                }
            });
            // === KẾT THÚC CODE POPUP ===

            // --- JAVASCRIPT CHO ĐỀ XUẤT TÌM KIẾM ---
            const searchInput = document.getElementById('favSearchInput');
            const suggestionsContainer = document.getElementById('favSearchSuggestions');
            const searchForm = document.getElementById('favSearchForm');

            if (searchInput) {
                searchInput.addEventListener('keyup', function() {
                    const term = this.value;
                    if (term.length < 2) {
                        suggestionsContainer.innerHTML = '';
                        suggestionsContainer.style.display = 'none';
                        return;
                    }
                    fetch('/Home/SearchSuggestions?term=' + term)
                         .then(response => response.json())
                         .then(data => {
                            suggestionsContainer.innerHTML = '';
                            if (data.length > 0) {
                                suggestionsContainer.style.display = 'block';
                                const header = document.createElement('div');
                                header.classList.add('suggestion-header');
                                header.textContent = 'Sản phẩm gợi ý';
                                suggestionsContainer.appendChild(header);
                                data.forEach(product => {
                                    const suggestionLink = document.createElement('a');
                                    suggestionLink.classList.add('suggestion-item');
                                    suggestionLink.href = `/Home/Index?searchString=${encodeURIComponent(product.name)}`;
                                    const img = document.createElement('img');
                                    let imageUrl = product.mainImage;
                                    if (imageUrl && !imageUrl.startsWith('http')) {
                                        imageUrl = imageUrl.replace("~", "");
                                    }
                                    img.src = imageUrl ? imageUrl : '/images/default-product.png';
                                    img.alt = product.name;
                                    const infoDiv = document.createElement('div');
                                    infoDiv.classList.add('suggestion-item-info');
                                    const nameDiv = document.createElement('div');
                                    nameDiv.classList.add('suggestion-item-name');
                                    nameDiv.textContent = product.name;
                                    const priceDiv = document.createElement('div');
                                    priceDiv.classList.add('suggestion-item-price');
                                    priceDiv.textContent = product.price.toLocaleString('vi-VN', { style: 'currency', currency: 'VND' });
                                    infoDiv.appendChild(nameDiv);
                                    infoDiv.appendChild(priceDiv);
                                    suggestionLink.appendChild(img);
                                    suggestionLink.appendChild(infoDiv);
                                    suggestionLink.addEventListener('click', function(e) {
                                        e.preventDefault();
                                        searchInput.value = product.name;
                                        searchForm.submit();
                                    });
                                    suggestionsContainer.appendChild(suggestionLink);
                                });
                            } else {
                                suggestionsContainer.style.display = 'none';
                            }
                        });
                });

                document.addEventListener('click', function(e) {
                    if (!searchForm.contains(e.target)) {
                        suggestionsContainer.style.display = 'none';
                    }
                });
            }
        });
    </script>
</body>
</html>