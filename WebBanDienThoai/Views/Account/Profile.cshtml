@* SỬA 1: Đổi tên Model cho khớp với file AccountViewModels.cs *@
@model WebBanDienThoai.ViewModels.AccountViewModels
@using System.Security.Claims

@{
    ViewData["Title"] = "Thông tin tài khoản";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Rabit Store</title>

    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/profile.css" asp-append-version="true" />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;700&display=swap" rel="stylesheet">
</head>
<body>

    <header class="site-header">
        <div class="header-top">
            <div class="container header-top-container">
                <a asp-controller="Home" asp-action="Index" class="logo">
                    <h1 class="logo-text">Rabit</h1>
                    <img src="~/images/linhvatcau.png" alt="Rabit Mascot" class="logo-mascot">
                    <h1 class="logo-text">Store</h1>
                </a>

                <form asp-controller="Home" asp-action="Index" method="get" class="search-form" id="mainSearchForm">
                    <input type="text" name="searchString"
                           value="" placeholder="Tìm kiếm" class="search-input" id="mainSearchInput" autocomplete="off">
                    <button type="submit" class="search-button">
                        <img src="~/images/search.png" alt="Search Icon">
                    </button>
                    <div class="search-suggestions" id="mainSearchSuggestions"></div>
                </form>

                <div class="header-actions">
                    <a href="#" class="cart-link">
                        <span>Giỏ hàng</span>
                        <img src="~/images/giohang.png" alt="Cart Icon">
                    </a>

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <div class="user-profile-dropdown">
                            <a href="#" class="user-profile">
                                <span>@User.FindFirstValue("FullName")</span>
                                <img src="~/images/user.png" alt="User Icon">
                            </a>
                            <div class="dropdown-content">
                                <a asp-controller="Account" asp-action="Profile">Trang cá nhân</a>
                                <a asp-controller="Account" asp-action="Logout">Đăng xuất</a>
                            </div>
                        </div>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Login" class="user-profile">
                            <span>Đăng nhập</span>
                            <img src="~/images/user.png" alt="User Icon">
                        </a>
                    }
                </div>
            </div>
        </div>
        <nav class="main-nav">
            <div class="container nav-container">
                <a asp-controller="Home" asp-action="Index">Trang chủ</a>
                <a asp-controller="Home" asp-action="Favorites">Yêu thích</a>

                <div class="nav-category-dropdown" id="categoryDropdown">
                    <a href="#" class="dropdown-link" id="categoryDropdownToggle">
                        Danh mục
                        <img src="~/images/chevron-down.png" alt="Dropdown arrow">
                    </a>
                    <div class="category-popup">
                        @* SỬA 2: Tạm thời ẩn logic BrandCounts vì AccountViewModels không có dữ liệu này.
                           Nếu muốn hiện danh mục, bạn phải thêm List<BrandCount> BrandCounts vào AccountViewModels.cs
                           và nạp dữ liệu từ Controller.
                        *@

                        @* Code cũ bị lỗi: *@
                        @* @if (Model.BrandCounts?.Count > 0) { ... } *@

                        @* Code thay thế tạm thời: *@
                        <a asp-controller="Home" asp-action="Index" class="category-popup-item">Tất cả sản phẩm</a>
                        <span class="category-popup-item" style="font-style:italic; font-size: 0.9em;">(Về trang chủ để xem danh mục đầy đủ)</span>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="profile-container">
        <h1>@ViewData["Title"]</h1>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success" style="color: green; background-color: #d4edda; padding: 10px; margin-bottom: 15px; border-radius: 5px;">
                @TempData["SuccessMessage"]
            </div>
        }

        <form asp-action="Profile" method="post" class="profile-form-grid">
            <div class="form-group full-width">
                <label asp-for="Email"></label>
                @* Email readonly *@
                <input asp-for="Email" class="form-control" readonly style="background-color: #e9ecef;" />
            </div>

            <hr class="full-width" style="border: 0; border-top: 1px solid #eee; margin: 20px 0;" />

            <div class="form-group">
                <label asp-for="FullName"></label>
                <input asp-for="FullName" class="form-control" />
                <span asp-validation-for="FullName" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Phone"></label>
                <input asp-for="Phone" class="form-control" />
                <span asp-validation-for="Phone" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="BirthDate"></label>
                <input asp-for="BirthDate" class="form-control" type="date" />
                <span asp-validation-for="BirthDate" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Gender"></label>
                <select asp-for="Gender" class="form-control">
                    <option value="">-- Chọn giới tính --</option>
                    <option value="Nam">Nam</option>
                    <option value="Nữ">Nữ</option>
                    <option value="Khác">Khác</option>
                </select>
                <span asp-validation-for="Gender" class="text-danger"></span>
            </div>

            <div class="form-actions full-width">
                <button type="submit" class="btn-save-profile">Lưu thay đổi</button>
            </div>
        </form>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // === CODE CHO POPUP DANH MỤC ===
            const categoryDropdown = document.getElementById('categoryDropdown');
            const categoryToggle = document.getElementById('categoryDropdownToggle');

            if (categoryToggle) {
                categoryToggle.addEventListener('click', function(e) {
                    e.preventDefault();
                    categoryDropdown.classList.toggle('active');
                });
            }

            document.addEventListener('click', function(e) {
                if (categoryDropdown && !categoryDropdown.contains(e.target)) {
                    categoryDropdown.classList.remove('active');
                }
            });

            // --- JAVASCRIPT CHO ĐỀ XUẤT TÌM KIẾM ---
            const searchInput = document.getElementById('mainSearchInput');
            const suggestionsContainer = document.getElementById('mainSearchSuggestions');
            const searchForm = document.getElementById('mainSearchForm');

            if (searchInput) {
                searchInput.addEventListener('keyup', function() {
                    const term = this.value;
                    if (term.length < 2) {
                        suggestionsContainer.innerHTML = '';
                        suggestionsContainer.style.display = 'none';
                        return;
                    }

                    fetch('/Home/SearchSuggestions?term=' + encodeURIComponent(term))
                        .then(response => {
                            if (!response.ok) {
                                throw new Error('Network response was not ok');
                            }
                            return response.json();
                        })
                        .then(data => {
                            suggestionsContainer.innerHTML = '';
                            if (data && data.length > 0) {
                                suggestionsContainer.style.display = 'block';
                                const header = document.createElement('div');
                                header.classList.add('suggestion-header');
                                header.textContent = 'Sản phẩm gợi ý';
                                suggestionsContainer.appendChild(header);

                                data.forEach(product => {
                                    const suggestionLink = document.createElement('a');
                                    suggestionLink.classList.add('suggestion-item');
                                    suggestionLink.href = `/Home/Index?searchString=${encodeURIComponent(product.name)}`;

                                    const img = document.createElement('img');
                                    let imageUrl = product.mainImage || '';
                                    if (imageUrl && !imageUrl.startsWith('http')) {
                                        imageUrl = imageUrl.replace("~", "");
                                    }
                                    img.src = imageUrl || '/images/default-product.png';
                                    img.alt = product.name || '';
                                    img.onerror = function() {
                                        this.src = '/images/default-product.png';
                                    };

                                    const infoDiv = document.createElement('div');
                                    infoDiv.classList.add('suggestion-item-info');

                                    const nameDiv = document.createElement('div');
                                    nameDiv.classList.add('suggestion-item-name');
                                    nameDiv.textContent = product.name || '';

                                    const priceDiv = document.createElement('div');
                                    priceDiv.classList.add('suggestion-item-price');
                                    priceDiv.textContent = (product.price || 0).toLocaleString('vi-VN', {
                                        style: 'currency',
                                        currency: 'VND'
                                    });

                                    infoDiv.appendChild(nameDiv);
                                    infoDiv.appendChild(priceDiv);
                                    suggestionLink.appendChild(img);
                                    suggestionLink.appendChild(infoDiv);

                                    suggestionLink.addEventListener('click', function(e) {
                                        e.preventDefault();
                                        searchInput.value = product.name || '';
                                        searchForm.submit();
                                    });

                                    suggestionsContainer.appendChild(suggestionLink);
                                });
                            } else {
                                suggestionsContainer.style.display = 'none';
                            }
                        })
                        .catch(error => {
                            console.error('Error fetching search suggestions:', error);
                            suggestionsContainer.style.display = 'none';
                        });
                });

                document.addEventListener('click', function(e) {
                    if (!searchForm.contains(e.target)) {
                        suggestionsContainer.style.display = 'none';
                    }
                });
            }
        });
    </script>

    @* Thêm thư viện jQuery để Validation hoạt động *@
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/jquery.validate.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@3.2.12/dist/jquery.validate.unobtrusive.min.js"></script>

</body>
</html>