@model WebBanDienThoai.Models.ViewModels.ForgotPasswordViewModel

@{
    ViewData["Title"] = "Quên mật khẩu";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="~/css/login.css" />
</head>
<body>
    <div class="login-container">
        <div class="brand-section">
            <img src="~/images/rabit-mascot.png" alt="Rabit Store" class="mascot" />
            <h1>Rabit Store</h1>
        </div>

        <div class="form-section">
            <form asp-action="ForgotPassword" method="post">
                <h2 class="mb-3">Quên mật khẩu?</h2>
                <p class="text-muted mb-4">Nhập email của bạn, chúng tôi sẽ gửi liên kết để đặt lại mật khẩu.</p>

                @if (ViewBag.Message != null)
                {
                    <div class="alert alert-success">@ViewBag.Message</div>
                }

                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="form-group mb-3">
                    <label asp-for="Email" class="form-label">Email đăng ký</label>
                    <input asp-for="Email" class="form-control" placeholder="vidu@gmail.com" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary w-100 py-2">Gửi yêu cầu</button>

                <div class="text-center mt-3">
                    <a asp-action="Login" class="text-decoration-none">← Quay lại đăng nhập</a>
                </div>
            </form>
        </div>
    </div>
</body>
</html>