@model WebBanDienThoai.Models.modelView.LoginViewModel
@{
    ViewData["Title"] = "Đăng Nhập - Rabit Store";
    Layout = null;
    // Vô hiệu hóa layout chung để có trang đăng nhập toàn màn hình
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    <link rel="stylesheet" href="~/css/login.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;700&display=swap" rel="stylesheet">
</head>
<body>

    <div class="login-container">
        <div class="brand-section">
            <img src="~/images/rabit-mascot.png" alt="Rabit Store Mascot" class="mascot" />

            <h1>Rabit Store</h1>
        </div>

        <div class="form-section">

            @* ======= KHỐI CODE ĐÃ THÊM: HIỂN THỊ TEMPDATA (Lỗi đăng ký thành công) ======= *@
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show mb-3" role="alert">
                    <strong>Thành công!</strong> @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @* ============================================================================== *@

            <form asp-action="Login" method="post">
                <h2>Đăng Nhập</h2>

                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="form-group">

                    <label asp-for="EmailOrPhone"></label>
                    <input asp-for="EmailOrPhone" class="form-control" />
                    <span asp-validation-for="EmailOrPhone" class="text-danger"></span>
                </div>

                <div class="form-group">

                    <label asp-for="Password"></label>
                    <input asp-for="Password" class="form-control" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <div class="form-options">

                    <div class="form-check">
                        <input asp-for="RememberMe" class="form-check-input" />
                        <label asp-for="RememberMe" class="form-check-label"></label>
                    </div>
                    <a href="#">Quên mật khẩu?</a>
                </div>

                <div class="form-group form-check" style="margin-top: 10px; text-align: left;">
                    <input asp-for="LoginAsAdmin" class="form-check-input" />
                    <label asp-for="LoginAsAdmin" class="form-check-label"></label>
                </div>

                <button type="submit" class="btn-login">Đăng nhập</button>

                <p class="signup-link">
                    Bạn chưa có tài khoản?
                    <a asp-action="Register" asp-controller="Account">Đăng Ký</a>
                </p>
            </form>
        </div>
    </div>

    @* Thêm Script Bootstrap để nút Close Alert hoạt động *@
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>