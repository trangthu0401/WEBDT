@using System.Security.Claims
@{
    // Logic lấy tên người dùng để hiển thị trên Header
    string userInitial = "?";
    string userFullName = "Guest";

    if (User.Identity.IsAuthenticated)
    {
        userFullName = User.FindFirstValue(ClaimTypes.GivenName) ?? User.Identity.Name;
        if (!string.IsNullOrEmpty(userFullName))
        {
            userInitial = userFullName.Trim().Substring(0, 1).ToUpper();
        }
    }

    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Rabit Store Admin</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <link href="~/css/master.css" rel="stylesheet" />
    <link href="~/css/tableStyle.css?v=7" rel="stylesheet" />
</head>
<body>

    <header>
        <div class="header-left">
            <img src="~/images/logo.png" alt="Rabit Store Logo" class="logo" />
        </div>

        <div class="header-right">
            <div class="header-search">
                <input type="text" placeholder="Tìm kiếm..." />
            </div>

            <div class="header-icons">
                <i class="fa-regular fa-bell"></i>
                <i class="fa-solid fa-gear"></i>

                <div class="dropdown">
                    <a href="#" class="dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                        <div class="avatar-initial" data-name="@userFullName">@userInitial</div>
                    </a>

                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><h6 class="dropdown-header">@userFullName</h6></li>
                        <li>
                            <a class="dropdown-item" asp-controller="Account" asp-action="Profile">
                                <i class="bi bi-person-circle"></i> Trang cá nhân
                            </a>
                        </li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <form asp-controller="Account" asp-action="Logout" method="post" id="logoutForm">
                                <button type="submit" class="dropdown-item text-danger">
                                    <i class="bi bi-box-arrow-right"></i> Đăng xuất
                                </button>
                            </form>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </header>

    <div class="main-container">
        <nav class="sidebar">
            <a href="~/Dashboard/Index" class="@(currentController == "Dashboard" ? "active" : "")">
                <i class="fa-solid fa-chart-line"></i> Tổng quan
            </a>

            <a href="~/Product/Index" class="@((currentController == "Product" || currentController == "ProductVariant") ? "active" : "")">
                <i class="fa-solid fa-box"></i> Sản phẩm
            </a>

            <a href="~/Customer/Index" class="@(currentController == "Customer" ? "active" : "")">
                <i class="fa-solid fa-user"></i> Khách hàng
            </a>

            <a href="~/Order/Index" class="@(currentController == "Order" ? "active" : "")">
                <i class="fa-solid fa-cube"></i> Đơn hàng
            </a>
        </nav>

        <main class="content">
            @RenderBody()
        </main>
    </div>

    <div class="modal fade" id="confirmationModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="confirmationModalLabel">Xác nhận</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" id="confirmationModalBody"></div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy bỏ</button>
                    <button type="button" class="btn btn-primary" id="confirmModalConfirmButton">
                        <span id="confirmModalActionButtonText">Xác nhận</span>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="reusableModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="reusableModalLabel">Thông báo</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" id="reusableModalBody"></div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-primary" data-bs-dismiss="modal">Đã hiểu</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function () {

            // --- A. Xử lý Thông báo từ TempData (Backend trả về) ---
            var successMsg = '@Html.Raw(TempData["SuccessMessage"] ?? "")';
            var errorMsg = '@Html.Raw(TempData["ErrorMessage"] ?? "")';

            if (successMsg || errorMsg) {
                var modalEl = document.getElementById('reusableModal');
                var title = document.getElementById('reusableModalLabel');
                var body = document.getElementById('reusableModalBody');
                var header = modalEl.querySelector('.modal-header');

                // Reset class
                header.classList.remove('bg-success', 'bg-danger', 'text-white');

                if (errorMsg) {
                    title.innerText = "Có lỗi xảy ra";
                    body.innerText = errorMsg;
                    header.classList.add('bg-danger', 'text-white');
                } else {
                    title.innerText = "Thành công";
                    body.innerText = successMsg;
                    header.classList.add('bg-success', 'text-white');
                }

                var modal = new bootstrap.Modal(modalEl);
                modal.show();
            }

            // --- B. Xử lý Màu Avatar Random ---
            const avatar = document.querySelector('.avatar-initial');
            if (avatar) {
                const name = avatar.getAttribute('data-name') || 'Guest';
                const colors = ['#dc3545', '#0d6efd', '#198754', '#6f42c1', '#fd7e14', '#d63384', '#20c997', '#6610f2'];

                let hash = 0;
                for (let i = 0; i < name.length; i++) {
                    hash = name.charCodeAt(i) + ((hash << 5) - hash);
                }

                const color = colors[Math.abs(hash) % colors.length];
                avatar.style.backgroundColor = color;
                avatar.style.borderColor = color;
            }

            // --- C. Xử lý Modal Xác nhận (cho các Form xóa/duyệt) ---
            const confirmModalElement = document.getElementById('confirmationModal');
            if (confirmModalElement) {
                const confirmModal = new bootstrap.Modal(confirmModalElement);
                let formToSubmit = null;

                document.querySelectorAll('form[data-confirm="true"]').forEach(form => {
                    form.addEventListener('submit', function (event) {
                        event.preventDefault();
                        formToSubmit = form;

                        // Lấy dữ liệu từ data attributes
                        const title = form.getAttribute('data-confirm-title') || 'Xác nhận';
                        const msg = form.getAttribute('data-confirm-message') || 'Bạn có chắc chắn?';
                        const btnText = form.getAttribute('data-confirm-button-text') || 'Xác nhận';
                        const btnClass = form.getAttribute('data-confirm-button-class') || 'btn-primary';
                        const headerClass = form.getAttribute('data-confirm-header-class') || '';

                        // Fill dữ liệu vào Modal
                        document.getElementById('confirmationModalLabel').innerText = title;
                        document.getElementById('confirmationModalBody').innerText = msg;
                        document.getElementById('confirmModalActionButtonText').innerText = btnText;

                        // Set style nút và header
                        const confirmBtn = document.getElementById('confirmModalConfirmButton');
                        confirmBtn.className = 'btn ' + btnClass;

                        const header = document.getElementById('confirmationModal').querySelector('.modal-header');
                        header.className = 'modal-header ' + headerClass;

                        confirmModal.show();
                    });
                });

                document.getElementById('confirmModalConfirmButton').addEventListener('click', function () {
                    if (formToSubmit) formToSubmit.submit();
                    confirmModal.hide();
                });
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>