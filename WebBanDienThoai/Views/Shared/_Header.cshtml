@using System.Security.Claims
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    string displayName = "Tài khoản";
    if (User.Identity.IsAuthenticated)
    {
        displayName = User.FindFirstValue("FullName") ?? User.Identity.Name;
        if (!string.IsNullOrEmpty(displayName) && displayName.Length > 12)
        {
            displayName = displayName.Substring(0, 12) + "...";
        }
    }
}

<header>
    <div class="header-top">
        <div class="header-container">
            <div class="logo-area">
                <a asp-controller="Home" asp-action="Index">
                    <span class="logo-text">Rabit</span>
                    <img src="~/images/linhvatcau.png" alt="Mascot" class="logo-img" />
                    <span class="logo-text">Store</span>
                </a>
            </div>

            <div class="search-area">
                <form asp-controller="Home" asp-action="Index" method="get" class="search-form" id="site-search-form" role="search" autocomplete="off">
                    <input type="text" id="site-search-input" name="searchString" class="search-input" placeholder="Tìm kiếm điện thoại, phụ kiện..." value="@(ViewData["CurrentSearch"] ?? "")" />
                    <button type="submit" class="search-btn" aria-label="Tìm kiếm">
                        <i class="fa-solid fa-magnifying-glass"></i>
                    </button>

                    <div id="search-suggestions" class="search-suggestions" aria-hidden="true"></div>
                </form>

                <style>
                    /* Inline minimal styles for suggestion box */
                    .search-suggestions {
                        position: absolute;
                        top: calc(100% + 8px);
                        left: 0;
                        right: 0;
                        max-width: 800px;
                        margin: 0 auto;
                        background: #fff;
                        border: 1px solid #e6e6e6;
                        border-radius: 8px;
                        box-shadow: 0 6px 18px rgba(0,0,0,0.08);
                        z-index: 9999;
                        display: none;
                        overflow: hidden;
                    }

                        .search-suggestions .ss-item {
                            display: flex;
                            align-items: center;
                            gap: 12px;
                            padding: 8px 12px;
                            cursor: pointer;
                            border-bottom: 1px solid #f1f1f1;
                        }

                            .search-suggestions .ss-item:last-child {
                                border-bottom: none;
                            }

                            .search-suggestions .ss-item:hover {
                                background: #f8f9fb;
                            }

                    .ss-thumb {
                        width: 40px;
                        height: 40px;
                        border-radius: 6px;
                        overflow: hidden;
                        flex-shrink: 0;
                        background: #f5f5f5;
                        display: flex;
                        align-items: center;
                        justify-content: center;
                    }

                        .ss-thumb img {
                            width: 100%;
                            height: 100%;
                            object-fit: cover;
                        }

                    .ss-meta {
                        flex: 1;
                        font-size: 14px;
                        color: #333;
                    }

                    .ss-price {
                        color: #dc3545;
                        font-weight: 700;
                        font-size: 13px;
                        white-space: nowrap;
                        margin-left: 8px;
                    }
                </style>

                <script>
                    (function () {
                        const form = document.getElementById('site-search-form');
                        const input = document.getElementById('site-search-input');
                        const suggestions = document.getElementById('search-suggestions');
                        let timer = null;

                        function clearSuggestions() {
                            suggestions.innerHTML = '';
                            suggestions.style.display = 'none';
                            suggestions.setAttribute('aria-hidden', 'true');
                        }

                        function render(items) {
                            if (!items || items.length === 0) { clearSuggestions(); return; }

                            suggestions.innerHTML = items.map(i => {
                                const name = i.name ? i.name.replace(/</g, "&lt;").replace(/>/g, "&gt;") : '';
                                const price = (i.price || 0).toLocaleString();
                                const img = i.mainImage ? (i.mainImage.startsWith('/') ? i.mainImage : '/' + i.mainImage) : '/images/placeholder.png';
                                return `<div class="ss-item" data-name="${encodeURIComponent(name)}">
                                            <div class="ss-thumb"><img src="${img}" alt="${name}"></div>
                                            <div class="ss-meta">${name}</div>
                                            <div class="ss-price">${price} vnd</div>
                                        </div>`;
                            }).join('');
                            suggestions.style.display = 'block';
                            suggestions.setAttribute('aria-hidden', 'false');

                            suggestions.querySelectorAll('.ss-item').forEach(el =>
                                el.addEventListener('click', () => {
                                    input.value = decodeURIComponent(el.dataset.name || '');
                                    form.submit();
                                })
                            );
                        }

                        input.addEventListener('input', function (e) {
                            const v = e.target.value.trim();
                            if (timer) clearTimeout(timer);
                            if (v.length < 2) { clearSuggestions(); return; }

                            timer = setTimeout(async () => {
                                try {
                                    const resp = await fetch(`/Home/SearchSuggestions?term=${encodeURIComponent(v)}`, { credentials: 'same-origin' });

                                    // Kiểm tra phản hồi từ server
                                    if (!resp.ok) {
                                        console.error("Lỗi HTTP từ server:", resp.status);
                                        clearSuggestions();
                                        return;
                                    }

                                    const data = await resp.json();
                                    render(data);
                                } catch (err) {
                                    // In lỗi ra console để debug thay vì im lặng
                                    console.error("Lỗi tìm kiếm gợi ý:", err);
                                    clearSuggestions();
                                }
                            }, 250);
                        });

                        // Close suggestions when clicking outside
                        document.addEventListener('click', (e) => {
                            if (!e.target.closest('#site-search-form')) clearSuggestions();
                        });

                        // Allow keyboard navigation (Enter submits)
                        input.addEventListener('keydown', (e) => {
                            if (e.key === 'Escape') clearSuggestions();
                            // Let Enter submit normally
                        });
                    })();
                </script>
            </div>

            <div class="header-actions">
                <a asp-controller="Cart" asp-action="Index" class="btn-cart-red position-relative">
                    <i class="fa-solid fa-cart-shopping"></i>
                    <span>Giỏ hàng</span>
                    <span id="cart-count-badge"
                          class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger"
                          style="font-size: 10px; display: none;">
                        0
                    </span>
                </a>

                <div class="dropdown">
                    <button class="btn-user-white" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="fa-regular fa-user"></i>
                        <span>@displayName</span>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end mt-2">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li><a class="dropdown-item" asp-controller="Account" asp-action="Profile">Hồ sơ cá nhân</a></li>
                            <li><a class="dropdown-item" asp-controller="OrderCustomer" asp-action="History">Đơn mua</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <form asp-controller="Account" asp-action="Logout" method="post">
                                    <button type="submit" class="dropdown-item text-danger">Đăng xuất</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li><a class="dropdown-item" asp-controller="Account" asp-action="Login">Đăng nhập</a></li>
                            <li><a class="dropdown-item" asp-controller="Account" asp-action="Register">Đăng ký</a></li>
                        }
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <nav class="header-nav">
        <ul class="nav-list">
            <li class="nav-item">
                <a asp-controller="Home" asp-action="Index">
                    <i class="fa-solid fa-house"></i> Trang chủ
                </a>
            </li>
            <li class="nav-item">
                <a asp-controller="Home" asp-action="Favorites">
                    <i class="fa-solid fa-heart"></i> Yêu thích
                </a>
            </li>
            <li class="nav-item">
                <a href="#">
                    <i class="fa-solid fa-gift"></i> Khuyến mãi
                </a>
            </li>
            <li class="nav-item">
                <a asp-controller="Home" asp-action="Contact">
                    <i class="fa-solid fa-headset"></i> Hỗ trợ
                </a>
            </li>
        </ul>
    </nav>
</header>