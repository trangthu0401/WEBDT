
﻿@using System.Security.Claims
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Rabit Store</title>

    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/css/customer-layout.css" rel="stylesheet" asp-append-version="true" />
    @RenderSection("Styles", required: false)
</head>
<body>

    @await Html.PartialAsync("_Header")

    <main class="main-content">
        @RenderBody()
    </main>

    <footer class="bg-light text-center py-3 border-top mt-5">
        <div class="container text-muted">
            &copy; 2025 Rabit Store - Hệ thống bán lẻ điện thoại chính hãng.
        </div>
    </footer>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // Script cập nhật số lượng giỏ hàng
        function updateCartCount() {
            $.ajax({
                url: '/Cart/GetCartCount',
                type: 'GET',
                success: function (res) {
                    var badge = $('#cart-count-badge');
                    if (res.count > 0) {
                        badge.text(res.count);
                        badge.show();
                    } else {
                        badge.hide();
                    }
                },
                error: function(err) {
                    console.log("Lỗi cập nhật giỏ hàng: ", err);
                }
            });
        }

        $(document).ready(function() {
            updateCartCount();
        });
    </script>

    @RenderSection("Scripts", required: false)

</body>
</html>
