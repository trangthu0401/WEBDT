@using System.Security.Claims
@{
    string displayName = "Tài khoản";
    string userInitial = "?";

    if (User.Identity.IsAuthenticated)
    {
        // Lấy trực tiếp từ Claim "FullName" (Đã lưu ở bước Login)
        // Không cần query lại DB -> Nhanh và chính xác theo phiên đăng nhập
        displayName = User.FindFirstValue("FullName") ?? User.Identity.Name;

        if (!string.IsNullOrEmpty(displayName))
        {
            userInitial = displayName.Trim().Substring(0, 1).ToUpper();
            if (displayName.Length > 12) displayName = displayName.Substring(0, 12) + "...";
        }
    }
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Rabit Store</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />

    <link href="~/css/customer-layout.css" rel="stylesheet" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <header>
        <div class="header-top">
            <div class="header-container">
                <div class="logo-area">
                    <a asp-controller="Home" asp-action="Index">
                        <span class="logo-text">Rabit</span>
                        <img src="~/images/linhvatcau.png" alt="Mascot" class="logo-img" />
                        <span class="logo-text">Store</span>
                    </a>
                </div>

                <div class="search-area">
                    <form asp-controller="Product" asp-action="Search" method="get" class="search-form">
                        <input type="text" name="query" class="search-input" placeholder="Tìm kiếm điện thoại, phụ kiện..." />
                        <button type="submit" class="search-btn">
                            <i class="fa-solid fa-magnifying-glass"></i>
                        </button>
                    </form>
                </div>

                <div class="header-actions">
                    <a asp-controller="Cart" asp-action="Index" class="btn-cart-red position-relative">
                        <i class="fa-solid fa-cart-shopping"></i>
                        <span>Giỏ hàng</span>

                        <span id="cart-count-badge"
                              class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger"
                              style="font-size: 10px; display: none;">
                            0
                        </span>
                    </a>

                    <div class="dropdown">
                        <button class="btn-user-white" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="fa-regular fa-user"></i>
                            <span>@displayName</span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end mt-2">
                            @if (User.Identity.IsAuthenticated)
                            {
                                <li><a class="dropdown-item" asp-controller="Account" asp-action="Profile">Hồ sơ cá nhân</a></li>
                                <li><a class="dropdown-item" asp-controller="Order" asp-action="History">Đơn mua</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <form asp-controller="Account" asp-action="Logout" method="post">
                                        <button type="submit" class="dropdown-item text-danger">Đăng xuất</button>
                                    </form>
                                </li>
                            }
                            else
                            {
                                <li><a class="dropdown-item" asp-controller="Account" asp-action="Login">Đăng nhập</a></li>
                                <li><a class="dropdown-item" asp-controller="Account" asp-action="Register">Đăng ký</a></li>
                            }
                        </ul>
                    </div>
                </div>
            </div>
        </div>

        <nav class="header-nav">
            <ul class="nav-list">
                <li class="nav-item">
                    <a asp-controller="Home" asp-action="Index">
                        <i class="fa-solid fa-house"></i> Trang chủ
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-controller="Product" asp-action="Wishlist">
                        <i class="fa-solid fa-heart"></i> Yêu thích
                    </a>
                </li>
                <li class="nav-item">
                    <a href="#">
                        <i class="fa-solid fa-gift"></i> Khuyến mãi
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-controller="Home" asp-action="Contact">
                        <i class="fa-solid fa-headset"></i> Hỗ trợ
                    </a>
                </li>
            </ul>
        </nav>
    </header>

    <main class="main-content">
        @RenderBody()
    </main>

    <footer class="bg-light text-center py-3 border-top">
        <div class="container text-muted">
            &copy; 2025 Rabit Store - Hệ thống bán lẻ điện thoại chính hãng.
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script>
        // Hàm cập nhật số lượng giỏ hàng Global
        function updateCartCount() {
            $.ajax({
                url: '/Cart/GetCartCount',
                type: 'GET',
                success: function (res) {
                    var badge = $('#cart-count-badge');
                    if (res.count > 0) {
                        badge.text(res.count);
                        badge.show(); // Hiện nếu có sản phẩm
                    } else {
                        badge.hide(); // Ẩn nếu = 0
                    }
                },
                error: function(err) {
                    console.log("Lỗi cập nhật giỏ hàng", err);
                }
            });
        }

        // Gọi hàm này ngay khi trang vừa load xong để hiển thị số lượng hiện tại
        $(document).ready(function() {
            updateCartCount();
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>