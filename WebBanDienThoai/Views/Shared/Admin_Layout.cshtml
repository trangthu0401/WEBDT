@{
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Rabit Store Admin</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://getbootstrap.com/docs/5.3/assets/css/docs.css" rel="stylesheet">
    <script defer src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <div class="admin-layout">
        <aside class="sidebar">
            <div class="logo">
             
                <img src="~/Image/Admin/logo.png" alt="Rabit Store mascot" class="logo-img" />
                
            </div>
            <nav class="sidebar-nav">
                <ul>
                    <li class="nav-item @(currentAction == "Index" ? "active" : "")">
                        <a href="/Admin/Index">
                            <img src="~/Image/Admin/Dashboard/admin_home_ic.png" alt="" />
                            <span>Tổng quan</span>
                        </a>
                    </li>
                    <li class="nav-item @(currentAction == "ManageProducts" ? "active" : "")">
                        <a href="/Admin/ManageProducts">
                            <img src="~/Image/Admin/Dashboard/admin_gift_nav_ic.png" alt="" />
                            <span>Sản phẩm</span>
                        </a>
                    </li>
                    <li class="nav-item @(currentAction == "Customers" ? "active" : "")">
                        <a href="/Admin/Customers">
                            <img src="~/Image/Admin/Dashboard/admin_user_nav_ic.png" alt="" />
                            <span>Khách hàng</span>
                        </a>
                    </li>
                    <li class="nav-item @(currentAction == "Orders" ? "active" : "")">
                        <a href="/Admin/Orders">
                            <img src="~/Image/Admin/Dashboard/admin_orer_ic.png" alt="" />
                            <span>Đơn hàng</span>
                        </a>
                    </li>
                    <li class="nav-item @(currentAction == "Reviews" ? "active" : "")">
                        <a href="/Admin/Reviews">
                            <img src="~/Image/Admin/Dashboard/admin_danhgia_ic.png" alt="" />
                            <span>Đánh giá</span>
                        </a>
                    </li>
                </ul>
            </nav>
        </aside>

        <main class="main-content">
            <header class="main-header">
                <div class="search-bar">
                    <input type="text" placeholder="Tìm kiếm" />
                    <button class="search-button">
                        <img src="~/Image/Admin/search.png" alt="Search Icon" />
                    </button>
                </div>
                <div class="header-actions">
                    <button class="icon-button">
                        <img src="~/Image/Admin/notification-1.png" alt="Notifications" />
                    </button>
                    <button class="icon-button">
                        <img src="~/Image/Admin/settings 1.png" alt="Settings" />
                    </button>
                    <img src="~/assets/user.png" alt="User Avatar" class="user-avatar" />
                </div>
            </header>

       

                <!-- Nội dung động từ view con -->
                <section class="dynamic-content">
                    @RenderBody()
                </section>
            </div>
        </main>
    </div>

    @RenderSection("Scripts", required: false)
</body>
</html>
