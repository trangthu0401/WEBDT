@model WebBanDienThoai.Models.ViewModels.ProductVariantIndexViewModel

@{
    // GHI CHÚ: Đã đổi Model
    ViewData["Title"] = "Chi tiết: " + Model.Product.Name;
}

<div class="products-container">

    <div class="mb-3">
        <!-- GHI CHÚ: Đường dẫn này trỏ về ProductController, là đúng -->
        <a href="@Url.Action("Index", "Product")" class="btn btn-secondary btn-sm" style="display: inline-flex; align-items: center; gap: 5px;">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-chevron-left" viewBox="0 0 16 16">
                <path fill-rule="evenodd" d="M11.354 1.646a.5.5 0 0 1 0 .708L5.707 8l5.647 5.646a.5.5 0 0 1-.708.708l-6-6a.5.5 0 0 1 0-.708l6-6a.5.5 0 0 1 .708 0" />
            </svg>
            Quay lại danh sách
        </a>
    </div>

    @* --- THÔNG TIN CHUNG SẢN PHẨM --- *@
    <div class="card mb-4">
        <div class="card-header">
            <h3 class="card-title h5 mb-0">Thông tin chung: @Model.Product.Name</h3>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-4">
                    <div class="product-image" style="width: 100%; height: auto; background-color: #f8f9fa; border-radius: 8px; overflow: hidden;">
                        <img src="@(Model.Product.MainImage ?? "/images/placeholder.png")" alt="@Model.Product.Name" style="width: 100%; height: auto; object-fit: contain;" />
                    </div>
                </div>
                <div class="col-md-8">
                    <dl class="row">
                        <dt class="col-sm-4">Hãng:</dt>
                        <dd class="col-sm-8 fw-bold">@(Model.Product.Brand?.BrandName ?? "N/A")</dd>
                        <dt class="col-sm-4">Chipset:</dt>
                        <dd class="col-sm-8">@Model.Product.Chipset</dd>
                        <dt class="col-sm-4">Hệ điều hành:</dt>
                        <dd class="col-sm-8">@Model.Product.OperatingSystem</dd>
                        <dt class="col-sm-4">Màn hình:</dt>
                        <dd class="col-sm-8">@Model.Product.ScreenSize" - @Model.Product.ScreenTech</dd>
                        <dt class="col-sm-4">Ngày nhập:</dt>
                        <dd class="col-sm-8">@(Model.Product.CreatedDate.ToString("dd/MM/yyyy h:mm tt") ?? "N/A")</dd>
                        <dt class="col-sm-4">Trạng thái:</dt>
                        <dd class="col-sm-8">
                            <span class="status-chip @(Model.Product.IsActive == true ? "available" : "hidden")">
                                @(Model.Product.IsActive == true ? "Đang bán" : "Đã ẩn")
                            </span>
                        </dd>
                        <dt class="col-sm-12 mt-3">Mô tả:</dt>
                        <dd class="col-sm-12" style="font-size: 0.95rem;">@Html.Raw(Model.Product.Description ?? "Chưa có mô tả.")</dd>
                    </dl>
                </div>
            </div>
        </div>
    </div>

    @* --- DANH SÁCH BIẾN THỂ --- *@
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h3 class="card-title h5 mb-0">Danh sách Biến thể (SKUs)</h3>
            <button type="button" class="btn btn-primary btn-sm"
                    data-bs-toggle="modal"
                    data-bs-target="#addVariantModal">
                Thêm Biến Thể Mới
            </button>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" style="font-size: 0.9rem;">
                    <thead class="table-light" style="font-size: 13px; text-transform: uppercase;">
                        <tr>
                            <th scope="col" style="width: 80px;">Ảnh</th>
                            <th scope="col">ID</th>
                            <th scope="col">Màu</th>
                            <th scope="col">Dung lượng</th>
                            <th scope="col">RAM</th>
                            <th scope="col" class="text-end">Giá</th>
                            <th scope="col" class="text-end">Giá KM</th>
                            <th scope="col" class="text-center">Tồn kho</th>
                            <th scope="col" class="text-center">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var variant in Model.Variants.OrderBy(v => v.Color))
                        {
                            <tr>
                                <td>
                                    <div class="product-image" style="width: 50px; height: 50px;">
                                        <img src="@(variant.ImageUrl ?? Model.Product.MainImage ?? "/images/placeholder.png")" alt="@variant.Color" />
                                    </div>
                                </td>
                                <td>@variant.VariantId</td>
                                <td>@variant.Color</td>
                                <td>@variant.Storage</td>
                                <td>@variant.RAM</td>
                                <td class="text-end @(variant.DiscountPrice.HasValue? "text-decoration-line-through text-muted" : "fw-bold")">
                                    @String.Format("{0:N0}", variant.Price) đ
                                </td>
                                <td class="text-end fw-bold text-danger">
                                    @(variant.DiscountPrice.HasValue? String.Format("{0:N0} đ", variant.DiscountPrice) : "N/A")
                                </td>
                                <td class="text-center">
                                    <span class="badge @(variant.Stock > 0 ? "bg-success" : "bg-danger")">
                                        @variant.Stock
                                    </span>
                                </td>
                                <td class="text-center">
                                    <div class="crud" style="justify-content: center;">

                                        @* === NÚT SỬA === *@
                                        <button type="button"
                                                class="btn-edit"
                                                data-bs-toggle="modal"
                                                data-bs-target="#editVariantModal"
                                                data-variant-id="@variant.VariantId"
                                                data-variant-color="@variant.Color"
                                                data-variant-storage="@variant.Storage"
                                                data-variant-ram="@variant.RAM"
                                                data-variant-price="@variant.Price"
                                                data-variant-discount="@variant.DiscountPrice.GetValueOrDefault(0)"
                                                data-variant-stock="@variant.Stock"
                                                title="Sửa biến thể này">
                                            <img src="/images/Admin/Product/edit.png" alt="Edit">
                                        </button>

                                        @* Nút Xóa (Kích hoạt Modal Xóa) *@
                                        <button type="button"
                                                class="btn-delete"
                                                data-bs-toggle="modal"
                                                data-bs-target="#deleteVariantModal"
                                                data-variant-id="@variant.VariantId"
                                                data-variant-name="@(variant.Color) @(variant.Storage)"
                                                title="Xóa biến thể này">
                                            <img src="/images/Admin/Product/delete.png" alt="Delete">
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                        @if (!Model.Variants.Any())
                        {
                            <tr>
                                <td colspan="9" class="text-center p-3">Sản phẩm này chưa có biến thể nào.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@* ------------------------------------------------------------------------------------------------------------------------------------------------- *@
@* MODAL THÊM BIẾN THỂ MỚI *@
<div class="modal fade" id="addVariantModal" tabindex="-1" aria-labelledby="addVariantModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="addVariantModalLabel">Thêm Biến Thể Mới cho Sản phẩm ID: @Model.Product.ProductId</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <!-- GHI CHÚ: Đã sửa asp-action="Create" và asp-controller="ProductVariant" -->
            <form asp-action="Create" asp-controller="ProductVariant" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <!-- GHI CHÚ: Đã sửa asp-for trỏ vào CreateForm -->
                    <input type="hidden" asp-for="CreateForm.ProductId" />

                    <div class="row">
                        <div class="col-md-6">
                            <h6 class="mb-3 text-danger">Thông số biến thể</h6>
                            <div class="mb-3">
                                <label asp-for="CreateForm.Color" class="form-label">Màu sắc</label>
                                <input asp-for="CreateForm.Color" class="form-control" placeholder="Ví dụ: Xanh dương" required>
                            </div>
                            <div class="mb-3">
                                <label asp-for="CreateForm.Storage" class="form-label">Dung lượng (GB)</label>
                                <input asp-for="CreateForm.Storage" class="form-control auto-gb" placeholder="Chỉ nhập số, ví dụ: 128" required>
                            </div>
                            <div class="mb-3">
                                <label asp-for="CreateForm.Ram" class="form-label">RAM (GB)</label>
                                <input asp-for="CreateForm.Ram" class="form-control auto-gb" placeholder="Chỉ nhập số, ví dụ: 8">
                            </div>
                        </div>
                        <div class="col-md-6 border-start">
                            <h6 class="mb-3 text-danger">Giá & Tồn kho</h6>
                            <div class="mb-3">
                                <label asp-for="CreateForm.Price" class="form-label">Giá bán gốc (vnd)</label>
                                <input asp-for="CreateForm.Price" type="number" step="1000" min="0" class="form-control" required>
                            </div>
                            <div class="mb-3">
                                <label asp-for="CreateForm.DiscountPrice" class="form-label">Giá khuyến mãi (vnd - Để trống nếu không KM)</label>
                                <input asp-for="CreateForm.DiscountPrice" type="number" step="1000" min="0" class="form-control">
                            </div>
                            <div class="mb-3">
                                <label asp-for="CreateForm.Stock" class="form-label">Số lượng tồn kho</label>
                                <input asp-for="CreateForm.Stock" type="number" min="0" class="form-control" required>
                            </div>
                            <div class="mb-3">
                                <label asp-for="CreateForm.ImageFile" class="form-label">Ảnh Biến thể (Tùy chọn)</label>
                                <input asp-for="CreateForm.ImageFile" class="form-control" type="file">
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                    <button type="submit" class="btn btn-primary">Lưu Biến Thể</button>
                </div>
            </form>
        </div>
    </div>
</div>
@* ------------------------------------------------------------------------------------------------------------------------------------------------- *@

@* MODAL XÓA BIẾN THỂ *@
<form asp-action="Delete" asp-controller="ProductVariant" method="post" id="deleteVariantForm">

    <div class="modal fade" id="deleteVariantModal" tabindex="-1" aria-labelledby="deleteVariantModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">

                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title" id="deleteVariantModalLabel">Xác nhận Xóa Biến thể</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body">
                    <p>Bạn chắc chắn muốn xóa biến thể này?</p>
                    <p class="text-danger fw-bold" id="variant-to-delete-name"></p>
                    <small class="text-muted">Hành động này không thể hoàn tác.</small>

                    @Html.AntiForgeryToken()
                    <input type="hidden" name="variantId" id="delete-variant-id-input" value="0" />
                    <input type="hidden" name="productId" value="@Model.Product.ProductId" />
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-danger">Xóa Biến Thể</button>
                </div>

            </div>
        </div>
    </div>

</form>
@* ------------------------------------------------------------------------------------------------------------------------------------------------- *@

@* MODAL SỬA BIẾN THỂ *@
<div class="modal fade" id="editVariantModal" tabindex="-1" aria-labelledby="editVariantModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="editVariantModalLabel">Sửa Biến Thể (ID: <span id="edit-variant-id-display"></span>)</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <!-- GHI CHÚ: Đã sửa asp-action="Edit" và asp-controller="ProductVariant" -->
            <!-- GHI CHÚ: Form này đã tương thích với ProductVariantEditViewModel -->
            <form asp-action="Edit" asp-controller="ProductVariant" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <input type="hidden" name="ProductId" value="@Model.Product.ProductId" />
                    <input type="hidden" name="VariantId" id="edit-variant-id" />

                    <div class="row">
                        <div class="col-md-6">
                            <h6 class="mb-3 text-primary">Thông số biến thể</h6>
                            <div class="mb-3">
                                <label for="edit-variant-color" class="form-label">Màu sắc</label>
                                <input type="text" class="form-control" id="edit-variant-color" name="Color" required>
                            </div>
                            <div class="mb-3">
                                <label for="edit-variant-storage" class="form-label">Dung lượng (GB)</label>
                                <input type="text" class="form-control auto-gb" id="edit-variant-storage" name="Storage" required>
                            </div>
                            <div class="mb-3">
                                <label for="edit-variant-ram" class="form-label">RAM (GB)</label>
                                <input type="text" class="form-control auto-gb" id="edit-variant-ram" name="Ram">
                            </div>
                        </div>
                        <div class="col-md-6 border-start">
                            <h6 class="mb-3 text-primary">Giá & Tồn kho</h6>
                            <div class="mb-3">
                                <label for="edit-variant-price" class="form-label">Giá bán gốc (vnd)</label>
                                <input type="number" step="1000" min="0" class="form-control" id="edit-variant-price" name="Price" required>
                            </div>
                            <div class="mb-3">
                                <label for="edit-variant-discount" class="form-label">Giá khuyến mãi (vnd)</label>
                                <input type="number" step="1000" min="0" class="form-control" id="edit-variant-discount" name="DiscountPrice">
                            </div>
                            <div class="mb-3">
                                <label for="edit-variant-stock" class="form-label">Số lượng tồn kho</label>
                                <input type="number" min="0" class="form-control" id="edit-variant-stock" name="Stock" required>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                    <button type="submit" class="btn btn-primary">Lưu Thay Đổi</button>
                </div>
            </form>
        </div>
    </div>
</div>
@* ------------------------------------------------------------------------------------------------------------------------------------------------- *@


@* ================================================================== *@
@* === JAVASCRIPT CHO CÁC MODAL === *@
@* ================================================================== *@
<script>
    document.addEventListener('DOMContentLoaded', function () {
        // --- Code xử lý 'auto-gb' ---
        const inputs = document.querySelectorAll('.auto-gb');
        inputs.forEach(input => {
            // Khi rời khỏi input
            input.addEventListener('blur', function () {
                let value = this.value.trim();
                if (value) {
                    const numericValue = value.match(/^\d+/); // Lấy số
                    if (numericValue && numericValue[0]) {
                        this.value = numericValue[0] + 'GB';
                    }
                    else {
                        this.value = ''; // Xóa nếu không phải là số
                    }
                }
            });
            // Khi focus vào input
            input.addEventListener('focus', function () {
                let value = this.value;
                if (value.endsWith('GB')) {
                    this.value = value.replace('GB', '');
                }
            });
        });

        // --- Code xử lý Modal Xóa (Delete) ---
        var deleteModal = document.getElementById('deleteVariantModal');
        if (deleteModal) {
            deleteModal.addEventListener('show.bs.modal', function (event) {
                var button = event.relatedTarget;
                var variantId = button.getAttribute('data-variant-id');
                var variantName = button.getAttribute('data-variant-name');

                var idInput = deleteModal.querySelector('#delete-variant-id-input');
                var nameDisplay = deleteModal.querySelector('#variant-to-delete-name');

                if (idInput) { idInput.value = variantId; }
                if (nameDisplay) { nameDisplay.textContent = "Biến thể: " + variantName; }
            });
        }

        // --- Code xử lý Modal Sửa (Edit) ---
        var editModal = document.getElementById('editVariantModal');
        if (editModal) {
            editModal.addEventListener('show.bs.modal', function (event) {
                var button = event.relatedTarget;

                // Lấy dữ liệu từ data-* attributes
                var id = button.getAttribute('data-variant-id');
                var color = button.getAttribute('data-variant-color');
                var storage = button.getAttribute('data-variant-storage');
                var ram = button.getAttribute('data-variant-ram'); // Có thể null
                var price = button.getAttribute('data-variant-price');
                var discount = button.getAttribute('data-variant-discount');
                var stock = button.getAttribute('data-variant-stock');

                // Lấy các element trong form của modal sửa
                var idDisplay = editModal.querySelector('#edit-variant-id-display');
                var idInput = editModal.querySelector('#edit-variant-id');
                var colorInput = editModal.querySelector('#edit-variant-color');
                var storageInput = editModal.querySelector('#edit-variant-storage');
                var ramInput = editModal.querySelector('#edit-variant-ram');
                var priceInput = editModal.querySelector('#edit-variant-price');
                var discountInput = editModal.querySelector('#edit-variant-discount');
                var stockInput = editModal.querySelector('#edit-variant-stock');

                // Gán dữ liệu vào các trường
                if(idDisplay) idDisplay.textContent = id;
                if(idInput) idInput.value = id;
                if(colorInput) colorInput.value = color;

                // Xử lý "GB" trước khi gán
                if(storageInput) storageInput.value = storage.replace('GB', '');

                // GHI CHÚ: Đã sửa lỗi JS (ram có thể null)
                if(ramInput) ramInput.value = (ram ? ram.replace('GB', '') : '');

                if(priceInput) priceInput.value = price;
                if(discountInput) discountInput.value = discount;
                if(stockInput) stockInput.value = stock;
            });
        }
    });
</script>


@* CSS (Nội tuyến) *@
<style>
    .crud {
        display: flex;
        align-items: center;
        gap: 8px;
        justify-content: center;
    }

        .crud form {
            display: inline-block;
            margin: 0;
            padding: 0;
            line-height: 1;
        }

    .btn-delete, .btn-edit {
        background: none;
        border: none;
        padding: 0;
        cursor: pointer;
        line-height: 1;
    }

    .crud a img, .crud button img {
        height: 16px;
        width: auto;
        vertical-align: middle;
        opacity: 0.7;
        transition: opacity 0.2s;
    }

    .crud a:hover img, .crud button:hover img {
        opacity: 1;
    }

    .crud a, .crud button, .crud form {
        margin: 0;
    }

    /* Style cho ảnh (giữ nguyên) */
    .product-image {
        width: 60px;
        height: 60px;
        flex-shrink: 0;
        display: flex;
        justify-content: center;
        align-items: center;
        background-color: #f8f9fa;
        border-radius: 6px;
        overflow: hidden;
    }

        .product-image img {
            max-width: 100%;
            max-height: 100%;
            object-fit: contain;
            display: block;
        }

    .btn-close-white {
        filter: invert(1) grayscale(100%) brightness(200%);
    }

    /* Style cho 'status-chip' (từ file Index.cshtml) */
    .status-chip {
        padding: 4px 10px;
        border-radius: 12px;
        font-size: 0.8rem;
        font-weight: 600;
    }

        .status-chip.available {
            background-color: #d1e7dd; /* green */
            color: #0f5132;
        }

        .status-chip.hidden {
            background-color: #e2e3e5; /* gray */
            color: #41464b;
        }
</style>