@model WebBanDienThoai.Models.ViewModels.OrderDetailViewModel
@using System.Globalization
@{
    ViewData["Title"] = $"Chi tiết Đơn hàng #{Model.OrderId}";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    // --- Logic hiển thị Thanh tiến trình (Progress Bar) ---
    string progressWidth = "0%";
    bool s1 = true, s2 = false, s3 = false, s4 = false;
    bool isCancelled = Model.OrderStatus == "Đã hủy";

    switch (Model.OrderStatus)
    {
        case "Chờ xác nhận":
        case "Đang xử lý":
            progressWidth = "33%";
            s2 = true;
            break;
        case "Đang giao":
            progressWidth = "66%";
            s2 = true; s3 = true;
            break;
        case "Đã giao":
            progressWidth = "100%";
            s2 = true; s3 = true; s4 = true;
            break;
    }
}

<style>
    .progress-track {
        display: flex;
        justify-content: space-between;
        align-items: center;
        position: relative;
        max-width: 800px;
        margin: 40px auto;
        padding: 0 10px;
    }

        .progress-track::before {
            content: '';
            position: absolute;
            top: 50%;
            left: 0;
            right: 0;
            height: 4px;
            background-color: #e0e0e0;
            transform: translateY(-50%);
            z-index: 1;
            border-radius: 4px;
        }

    .progress-line {
        position: absolute;
        top: 50%;
        left: 0;
        height: 4px;
        background-color: #28a745;
        transform: translateY(-50%);
        z-index: 2;
        transition: width 0.5s ease;
        border-radius: 4px;
    }

    .progress-step {
        position: relative;
        z-index: 3;
        width: 45px;
        height: 45px;
        background-color: #fff;
        border: 4px solid #e0e0e0;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.5s ease;
    }

        .progress-step i {
            font-size: 18px;
            color: #e0e0e0;
            transition: color 0.5s ease;
        }

        .progress-step .step-label {
            position: absolute;
            top: 55px;
            left: 50%;
            transform: translateX(-50%);
            width: 120px;
            text-align: center;
            font-size: 13px;
            font-weight: 600;
            color: #999;
            background: #fff;
            padding: 2px 0;
        }

        .progress-step.active {
            border-color: #28a745;
            box-shadow: 0 0 0 4px rgba(40, 167, 69, 0.1);
        }

            .progress-step.active i {
                color: #28a745;
            }

            .progress-step.active .step-label {
                color: #000;
                font-weight: 700;
            }
</style>

<style>
    /* CSS cho đường viền bảng xám nhạt */
    .table {
        border: 1px solid #dee2e6;
        border-collapse: collapse;
    }

        .table thead {
            background: #f8f9fa;
            border-bottom: 2px solid #dee2e6;
        }

        .table th {
            border: none;
            padding: 12px 8px;
            font-weight: 600;
            color: #495057;
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            border-bottom: 2px solid #dee2e6;
            background: #f8f9fa;
        }

        .table td {
            padding: 12px 8px;
            vertical-align: middle;
            border-bottom: 1px solid #dee2e6;
            color: #333;
            font-size: 0.9rem;
        }

        .table tbody tr:last-child td {
            border-bottom: none;
        }

        .table tfoot {
            background: #f8f9fa;
            border-top: 2px solid #dee2e6;
        }

            .table tfoot td {
                border-top: 2px solid #dee2e6;
                font-weight: 600;
            }

    .table-hover tbody tr:hover {
        background-color: rgba(0, 0, 0, 0.02);
    }
</style>

<div class="container py-4">

    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <h2 class="fw-bold mb-0">Chi tiết Đơn hàng #@Model.OrderId</h2>
        <div class="d-flex gap-2">
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i> Quay lại
            </a>

            @if (!isCancelled && Model.OrderStatus != "Đã giao")
            {
                @if (Model.OrderStatus == "Chờ xác nhận" || Model.OrderStatus == "Đang xử lý")
                {
                    <button type="button" class="btn btn-primary" onclick="openShippingModal()">
                        <i class="bi bi-truck me-1"></i> Xác nhận & Giao hàng
                    </button>

                    <button type="button" class="btn btn-danger" onclick="openCancelModal()">
                        <i class="bi bi-x-circle me-1"></i> Hủy đơn
                    </button>
                }
                else if (Model.OrderStatus == "Đang giao")
                {
                    <form asp-action="ConfirmDelivered" method="post" class="d-inline">
                        <input type="hidden" name="orderId" value="@Model.OrderId" />
                        <button type="submit" class="btn btn-success" onclick="return confirm('Xác nhận khách đã nhận được hàng và thanh toán đủ?');">
                            <i class="bi bi-check-circle me-1"></i> Xác nhận Đã giao
                        </button>
                    </form>

                    <button type="button" class="btn btn-danger" onclick="openCancelModal()">
                        <i class="bi bi-x-circle me-1"></i> Hủy đơn
                    </button>
                }
            }
        </div>
    </div>

    <div class="card shadow-sm mb-4 border-0">
        <div class="card-body p-5">
            @if (isCancelled)
            {
                <div class="alert alert-danger text-center fw-bold mb-0">
                    <i class="bi bi-x-circle-fill me-2"></i> ĐƠN HÀNG ĐÃ BỊ HỦY
                </div>
            }
            else
            {
                <div class="progress-track">
                    <div class="progress-line" style="width: @progressWidth;"></div>

                    <div class="progress-step @(s1 ? "active" : "")">
                        <i class="bi bi-cart-check-fill"></i>
                        <div class="step-label">Đặt hàng</div>
                    </div>
                    <div class="progress-step @(s2 ? "active" : "")">
                        <i class="bi bi-clipboard-check-fill"></i>
                        <div class="step-label">Đã xác nhận</div>
                    </div>
                    <div class="progress-step @(s3 ? "active" : "")">
                        <i class="bi bi-truck-front-fill"></i>
                        <div class="step-label">Đang giao</div>
                    </div>
                    <div class="progress-step @(s4 ? "active" : "")">
                        <i class="bi bi-check-circle-fill"></i>
                        <div class="step-label">Hoàn tất</div>
                    </div>
                </div>
            }
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header text-white bg-danger">
                    <i class="bi bi-basket-fill me-1"></i> Danh sách Sản phẩm
                </div>
                <div class="card-body p-0">
                    <table class="table align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4 py-3">Sản phẩm</th>
                                <th class="text-center">Giá</th>
                                <th class="text-center">SL</th>
                                <th class="text-end pe-4">Tổng</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.OrderItems)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center">
                                            <img src="@Url.Content("~" + item.ImageUrl)" style="width: 50px; height: 50px; object-fit: contain; border: 1px solid #eee; border-radius: 4px;" />
                                            <div class="ms-3">
                                                <div class="fw-bold">@item.ProductName</div>
                                                <small class="text-muted">@item.Color - @item.Storage</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-center">@item.UnitPrice.ToString("N0")₫</td>
                                    <td class="text-center">@item.Quantity</td>
                                    <td class="text-end pe-4 fw-bold">@((item.UnitPrice * item.Quantity).ToString("N0"))₫</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-light">
                            <tr>
                                <td colspan="3" class="text-end fw-bold pe-3">Tổng tiền:</td>
                                <td class="text-end pe-4 text-danger fw-bold fs-5">@Model.TotalAmount.ToString("N0")₫</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm mb-3">
                <div class="card-header bg-light fw-bold">Người nhận</div>
                <div class="card-body">
                    <p class="mb-1 fw-bold">@Model.ShippingFullName</p>
                    <p class="mb-1"><i class="bi bi-telephone me-1"></i> @Model.ShippingPhone</p>
                    <p class="mb-0 text-muted small"><i class="bi bi-geo-alt me-1"></i> @Model.ShippingFullAddress</p>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-header bg-light fw-bold">Vận chuyển & Thanh toán</div>
                <div class="card-body">
                    <div class="mb-2">
                        <small class="text-muted d-block">Đơn vị vận chuyển</small>
                        <strong>@Model.Carrier</strong>
                    </div>
                    <div class="mb-2">
                        <small class="text-muted d-block">Mã vận đơn</small>
                        <span class="badge bg-info text-dark">@Model.TrackingNumber</span>
                    </div>
                    <hr />
                    <div class="mb-2">
                        <small class="text-muted d-block">Thanh toán</small>
                        <strong>@Model.PaymentMethod</strong>
                    </div>
                    <div>
                        <small class="text-muted d-block">Trạng thái</small>
                        @if (Model.PaymentStatus == "Đã thanh toán")
                        {
                            <span class="badge bg-success">@Model.PaymentStatus</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark">@Model.PaymentStatus</span>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="shippingModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="StartShipping" method="post">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">Tạo Vận Đơn</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="OrderId" value="@Model.OrderId" />

                    <div class="mb-3">
                        <label class="form-label fw-bold">Đơn vị vận chuyển</label>
                        <select class="form-select" name="Carrier" required>
                            <option value="">-- Chọn --</option>
                            <option value="Giao Hàng Nhanh">Giao Hàng Nhanh (GHN)</option>
                            <option value="Giao Hàng Tiết Kiệm">Giao Hàng Tiết Kiệm (GHTK)</option>
                            <option value="Viettel Post">Viettel Post</option>
                            <option value="J&T Express">J&T Express</option>
                            <option value="Shopee Express">Shopee Express</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Ngày giao dự kiến</label>
                        <input type="date" class="form-control" name="EstimatedDate"
                               value="@DateTime.Now.AddDays(3).ToString("yyyy-MM-dd")" required />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary">Xác nhận & Giao</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="cancelModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="CancelOrder" method="post">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">Hủy Đơn Hàng</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="orderId" value="@Model.OrderId" />

                    <div class="mb-3">
                        <label class="form-label fw-bold">Lý do hủy đơn</label>
                        <textarea class="form-control" name="cancelReason" rows="3" required placeholder="VD: Khách đổi ý, Sai thông tin, Hết hàng..."></textarea>
                    </div>

                    <div class="alert alert-warning small">
                        <i class="bi bi-exclamation-triangle-fill me-1"></i>
                        <strong>Lưu ý:</strong> Nếu đơn hàng đã ở trạng thái "Đang giao", hệ thống sẽ tự động hoàn trả số lượng sản phẩm về kho.
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                    <button type="submit" class="btn btn-danger">Xác nhận Hủy</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Hàm mở Modal Shipping an toàn
        function openShippingModal() {
            var el = document.getElementById('shippingModal');
            var modal = bootstrap.Modal.getOrCreateInstance(el);
            modal.show();
        }

        // Hàm mở Modal Cancel an toàn
        function openCancelModal() {
            var el = document.getElementById('cancelModal');
            var modal = bootstrap.Modal.getOrCreateInstance(el);
            modal.show();
        }
    </script>
}