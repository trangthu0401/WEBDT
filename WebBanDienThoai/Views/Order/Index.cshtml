@model List<WebBanDienThoai.Models.ViewModels.OrderViewModel>
@{
    ViewData["Title"] = "Quản lý đơn hàng";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var page = (int)ViewBag.Page;
    var totalPages = (int)ViewBag.TotalPages;

    // === LOGIC PHÂN TRANG ===
    int maxPageLinks = 3; // Số lượng link trang tối đa hiển thị
    var startPage = Math.Max(1, page - (maxPageLinks / 2));
    var endPage = Math.Min(totalPages, startPage + maxPageLinks - 1);

    // Điều chỉnh lại startPage nếu endPage chạm mốc totalPages
    if (endPage == totalPages)
    {
        startPage = Math.Max(1, totalPages - maxPageLinks + 1);
    }
    // === KẾT THÚC LOGIC ===
}

<!-- Link CSS cho thanh tìm kiếm và trạng thái (nhớ cache-busting) -->
<link href="~/css/searchStyle.css?v=1" rel="stylesheet" />
<link href="~/css/Admin_Order/orderStyle.css?v=1" rel="stylesheet" />
<div class="container mt-4">

    <!-- THANH FILTER -->
    <div class="filter-bar justify-content-between">
        <!-- Lọc theo ID -->
        <div class="w-50 custom-search-bar">
            <input type="text" id="searchId" placeholder="Nhập ID đơn hàng..."
                   value="@ViewBag.SearchId" aria-label="Search">
            <button type="button" onclick="filterSearch()"><i class="bi bi-search"></i></button>
        </div>

        <!-- Lọc Trạng thái -->
        <div class="w-25">
            <select id="statusFilter" class="form-select">
                <option value="">--Trạng thái đơn hàng--</option>
                <option value="Chờ xác nhận" selected="@(ViewBag.StatusFilter == "Chờ xác nhận")">Chờ xác nhận</option>
                <option value="Đang giao" selected="@(ViewBag.StatusFilter == "Đang giao")">Đang giao</option>
                <option value="Đã giao" selected="@(ViewBag.StatusFilter == "Đã giao")">Đã giao</option>
                <option value="Đã hủy" selected="@(ViewBag.StatusFilter == "Đã hủy")">Đã hủy</option>
            </select>
        </div>
    </div>
    
    <!-- Dòng 2: Lọc theo ngày -->
    <div class="filter-bar">
         <div class="w-25 d-flex align-items-center">
            <label for="startDate" class="form-label me-2 mb-0">Từ:</label>
            <input type="date" id="startDate" class="form-control" value="@ViewBag.StartDate">
        </div>
        <div class="w-25 d-flex align-items-center">
            <label for="endDate" class="form-label me-2 mb-0">Đến:</label>
            <input type="date" id="endDate" class="form-control" value="@ViewBag.EndDate">
        </div>
        <div class="ms-auto">
             <button class="btn btn-primary w-auto" type="button" onclick="filter()">
                <i class="bi bi-funnel-fill me-1"></i> Lọc
             </button>
        </div>
    </div>

    <!-- BẢNG -->
    <table class="table align-middle rounded-table table-hover-pointer">
        <thead>
            <tr>
                <th>ID</th>
                <th>TÊN KHÁCH HÀNG</th>
                <th>ĐỊA CHỈ</th>
                <th>NGÀY ĐẶT</th>
                <th>TRẠNG THÁI</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var order in Model)
            {
                <tr onclick="window.location.href = '@Url.Action("Details", "Order", new { id = order.OrderId })'">
                    <td>@order.OrderCode</td>
                    <td>@order.CustomerName</td>
                    <td>@order.ShippingAddress</td>
                    <td>@order.OrderDate?.ToString("dd/MM/yyyy")</td>
                    <td>
                        <!-- Logic hiển thị badge trạng thái -->
                        @if (order.Status == "Đã giao")
                        {
                            <span class="badge-status status-delivered">ĐÃ GIAO</span>
                        }
                        else if (order.Status == "Đang giao")
                        {
                            <span class="badge-status status-shipping">ĐANG GIAO</span>
                        }
                        else if (order.Status == "Đã hủy")
                        {
                            <span class="badge-status status-canceled">ĐÃ HỦY</span>
                        }
                        else
                        {
                            <span class="badge-status status-processing">CHỜ XÁC NHẬN</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <!-- PHÂN TRANG -->
    <div class="d-flex justify-content-between align-items-center mt-3">
        <div>Trang @(page) / @totalPages</div>
        <nav>
            <ul class="pagination mb-0">
                <!-- Nút 'Trước' -->
                <li class="page-item @(page <= 1 ? "disabled" : "")">
                    <a class="page-link" href="@Url.Action("Index", new { searchId = ViewBag.SearchId, statusFilter = ViewBag.StatusFilter, startDate = ViewBag.StartDate, endDate = ViewBag.EndDate, page = page - 1 })">‹</a>
                </li>

                <!-- Hiển thị '1 ...' nếu cần (LOGIC MỚI) -->
                @if (startPage > 1)
                {
                    <li class="page-item">
                        <a class="page-link" href="@Url.Action("Index", new { searchId = ViewBag.SearchId, statusFilter = ViewBag.StatusFilter, startDate = ViewBag.StartDate, endDate = ViewBag.EndDate, page = 1 })">1</a>
                    </li>
                    @if (startPage > 2)
                    {
                        <!-- Chỉ hiển thị '...' nếu cách trang 1 ít nhất 1 số -->
                        <li class="page-item disabled"><span class="page-link">...</span></li>
                    }
                }

                <!-- Vòng lặp các trang chính (chỉ lặp 5 trang) -->
                @for (int i = startPage; i <= endPage; i++)
                {
                    <li class="page-item @(i == page ? "active" : "")">
                        <a class="page-link" href="@Url.Action("Index", new { searchId = ViewBag.SearchId, statusFilter = ViewBag.StatusFilter, startDate = ViewBag.StartDate, endDate = ViewBag.EndDate, page = i })">@i</a>
                    </li>
                }

                <!-- Hiển thị '... [cuối]' nếu cần (LOGIC MỚI) -->
                @if (endPage < totalPages)
                {
                    @if (endPage < totalPages - 1)
                    {
                        <!-- Chỉ hiển thị '...' nếu cách trang cuối ít nhất 1 số -->
                        <li class="page-item disabled"><span class="page-link">...</span></li>
                    }
                    <li class="page-item">
                        <a class="page-link" href="@Url.Action("Index", new { searchId = ViewBag.SearchId, statusFilter = ViewBag.StatusFilter, startDate = ViewBag.StartDate, endDate = ViewBag.EndDate, page = totalPages })">@totalPages</a>
                    </li>
                }

                <!-- Nút 'Sau' -->
                <li class="page-item @(page >= totalPages ? "disabled" : "")">
                    <a class="page-link" href="@Url.Action("Index", new { searchId = ViewBag.SearchId, statusFilter = ViewBag.StatusFilter, startDate = ViewBag.StartDate, endDate = ViewBag.EndDate, page = page + 1 })">›</a>
                </li>
            </ul>
        </nav>
    </div>
</div>

<script>
    function filter() {
        const status = document.getElementById("statusFilter").value;
        const start = document.getElementById("startDate").value;
        const end = document.getElementById("endDate").value;
        
        window.location.href = `?statusFilter=${encodeURIComponent(status)}` +
                               `&startDate=${encodeURIComponent(start)}` +
                               `&endDate=${encodeURIComponent(end)}` +
                               `&page=1`;
    }

    function filterSearch() {
        const searchId = document.getElementById("searchId").value;

        window.location.href = `?searchId=${encodeURIComponent(searchId)}` +
                               `&page=1`;
    }
</script>