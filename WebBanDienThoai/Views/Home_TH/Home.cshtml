@{
    Layout = null; // Không lồng layout vào layout khác
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home</title>
    <link rel="stylesheet" href="~/css/home.css">
</head>
<body>
    <header class="site-header">
        <div class="header-top">
            <div class="container header-top-container">
                <a href="#" class="logo">
                    <h1 class="logo-text">Rabit</h1>
                    <img src="img/linhvatcau.png" alt="Rabit Mascot" class="logo-mascot">
                    <h1 class="logo-text">Store</h1>
                </a>
                <form class="search-form">
                    <input type="text" placeholder="Tìm kiếm" class="search-input">
                    <button type="submit" class="search-button">
                        <img src="img/search.png" alt="Search Icon">
                    </button>
                </form>
                <div class="header-actions">
                    <a href="#" class="cart-link">
                        <span>Giỏ hàng</span>
                        <img src="img/giohang.png" alt="Cart Icon">
                    </a>
                    <a href="#" class="user-profile">
                        <span>Trung</span>
                        <img src="img/user.png" alt="User Icon">
                    </a>
                </div>
            </div>
        </div>
        <nav class="main-nav">
            <div class="container nav-container">
                <a href="#">Trang chủ</a>
                <a href="#products">Yêu thích</a>
                <a href="#" class="dropdown-link">
                    Danh mục
                    <img src="img/chevron-down.png" alt="Dropdown arrow">
                </a>
            </div>
        </nav>
    </header>

    <section id="hero" class="hero-section">
        <div class="container hero-container">
            <aside class="category-sidebar">
                <ul>
                    <li><a href="#"><span>Điện thoại</span> <img src="img/next .png" alt="arrow"></a></li>
                    <li><a href="#"><span>Tablet</span> <img src="img/next .png" alt="arrow"></a></li>
                    <li><a href="#"><span>Tai nghe</span> <img src="img/next .png" alt="arrow"></a></li>
                    <li><a href="#"><span>Loa</span> <img src="img/next .png" alt="arrow"></a></li>
                    <li><a href="#"><span>Thu cũ</span> <img src="img/next .png" alt="arrow"></a></li>
                </ul>
            </aside>
            <div class="hero-carousel">
                <img src="https://cdn2.cellphones.com.vn/insecure/rs:fill:1036:450/q:90/plain/https://dashboard.cellphones.com.vn/storage/690x300_iPhone_17_Pro_Opensale_v3.png" alt="iPhone Air Banner" class="carousel-image">
                <button class="carousel-control prev">
                    <img src="img/muitenphai.png" alt="Previous">
                </button>
                <button class="carousel-control next">
                    <img src="img/muitenphai.png" alt="Next">
                </button>
            </div>
            <aside class="ads-sidebar">
                <a href="#" class="ad-banner">
                    <img src="img/poster1.png" alt="Watch Series Ad">
                    <a href="#" class="ad-banner">
                        <img src="img/poster2.png" alt="S25 Series Ad">
                    </a>
                </a>
            </aside>
        </div>
    </section>

    <section id="products" class="products-section">
        <div class="container">
            <div class="product-grid">
                <article class="product-card">
                    <img src="https://cdn2.cellphones.com.vn/insecure/rs:fill:300:300/q:90/plain/https://cellphones.com.vn/media/catalog/product/i/p/iphone_air-3_2.jpg" alt="Iphone 16 air / VN" class="product-image">
                    <div class="product-info">
                        <h3 class="product-name">Iphone 16 air / VN</h3>
                        <p class="product-price">24.890.000đ</p>
                        <button class="wishlist-button">
                            <img src="img/tym.png" alt="Wishlist heart">
                            <span>Yêu thích</span>
                        </button>
                    </div>
                </article>
                <article class="product-card">
                    <img src="https://cdn2.cellphones.com.vn/insecure/rs:fill:358:358/q:90/plain/https://cellphones.com.vn/media/catalog/product/d/i/dien-thoai-samsung-galaxy-s25_1__2.png" alt="Samsung S25 VN" class="product-image">
                    <div class="product-info">
                        <h3 class="product-name">Samsung S25 VN</h3>
                        <p class="product-price">19.690.000đ</p>
                        <button class="wishlist-button">
                            <img src="img/tym.png" alt="Wishlist heart">
                            <span>Yêu thích</span>
                        </button>
                    </div>
                </article>
                <article class="product-card">
                    <img src="https://cdn2.cellphones.com.vn/insecure/rs:fill:358:358/q:90/plain/https://cellphones.com.vn/media/catalog/product/d/i/dien-thoai-xiaomi-15_11_.png" alt="Xiaomi 15 5G" class="product-image">
                    <div class="product-info">
                        <h3 class="product-name">Xiaomi 15 5G</h3>
                        <p class="product-price">21.590.000đ</p>
                        <button class="wishlist-button">
                            <img src="img/tym.png" alt="Wishlist heart">
                            <span>Yêu thích</span>
                        </button>
                    </div>
                </article>
                <article class="product-card">
                    <img src="https://cdn2.cellphones.com.vn/insecure/rs:fill:358:358/q:90/plain/https://cellphones.com.vn/media/catalog/product/d/i/dien-thoai-sony-xperia-1-vii.png" alt="Sony Xperia VII" class="product-image">
                    <div class="product-info">
                        <h3 class="product-name">Sony Xperia VII</h3>
                        <p class="product-price">35.990.000đ</p>
                        <button class="wishlist-button">
                            <img src="img/tym.png" alt="Wishlist heart">
                            <span>Yêu thích</span>
                        </button>
                    </div>
                </article>
            </div>
        </div>
        <a href="#" class="fab-contact">
            <span>Liên hệ</span>
            <img src="img/lienhe.png" alt="Contact Icon">
        </a>
    </section>
</body>
</html>
