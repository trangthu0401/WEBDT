@model WebBanDienThoai.Models.ViewModels.CreateProductViewModel

@{
    Layout = "~/Views/Shared/Admin_Layout1.cshtml";
    ViewData["Title"] = "Thêm Sản Phẩm Mới";
}

<link href="~/css/Dashboard.css" rel="stylesheet" />

@* Bọc toàn bộ form trong một 'card' để trông giống pop-up *@
<div class="card shadow-sm">
    <div class="card-header">
        <h3 class="card-title mb-0">Thêm Sản Phẩm Mới</h3>
    </div>

    <form asp-action="CreateProduct" method="post" enctype="multipart/form-data">
        <div class="card-body">

            @* Dòng này RẤT QUAN TRỌNG, nó sẽ hiển thị các lỗi chung *@
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            @* --- PHẦN 1: THÔNG TIN CHUNG --- *@
            <h5 class="mb-3 text-primary">Thông tin chung (Sản phẩm)</h5>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Product.Name" class="form-label">Tên sản phẩm</label>
                    <input asp-for="Product.Name" class="form-control" />
                    <span asp-validation-for="Product.Name" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Product.BrandId" class="form-label">Hãng sản xuất</label>
                    <select asp-for="Product.BrandId" asp-items="Model.BrandList" class="form-select">
                        <option value="">-- Vui lòng chọn hãng --</option>
                    </select>
                    <span asp-validation-for="Product.BrandId" class="text-danger"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Product.Chipset" class="form-label">Chipset</label>
                    <input asp-for="Product.Chipset" class="form-control" />
                    <span asp-validation-for="Product.Chipset" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Product.OperatingSystem" class="form-label">Hệ điều hành</label>
                    <input asp-for="Product.OperatingSystem" class="form-control" />
                    <span asp-validation-for="Product.OperatingSystem" class="text-danger"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-12 mb-3">
                    <label asp-for="MainImageFile" class="form-label">Ảnh đại diện (Tải lên)</label>
                    <input asp-for="MainImageFile" type="file" class="form-control" accept="image/png, image/jpeg" />
                    <span asp-validation-for="MainImageFile" class="text-danger"></span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Product.Description" class="form-label">Mô tả</label>
                <textarea asp-for="Product.Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Product.Description" class="text-danger"></span>
            </div>

            <hr class="my-4">

            @* --- PHẦN 2: BIẾN THỂ ĐẦU TIÊN --- *@
            <h5 class="mb-3 text-primary">Biến thể đầu tiên (SKU)</h5>
            <p class="text-muted small">Bạn có thể thêm các biến thể khác (màu sắc, dung lượng) sau khi tạo sản phẩm.</p>

            <div class="row">
                <div class="col-md-4 mb-3">
                    <label asp-for="VariantColor" class="form-label">Màu sắc</label>
                    <input asp-for="VariantColor" class="form-control" />
                    <span asp-validation-for="VariantColor" class="text-danger"></span>
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="VariantStorage" class="form-label">Dung lượng (Storage)</label>
                    <input asp-for="VariantStorage" class="form-control" placeholder="Ví dụ: 256GB" />
                    <span asp-validation-for="VariantStorage" class="text-danger"></span>
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="VariantRam" class="form-label">RAM</label>
                    <input asp-for="VariantRam" class="form-control" placeholder="Ví dụ: 8GB" />
                    <span asp-validation-for="VariantRam" class="text-danger"></span>
                </div>
            </div>
            <div class="row">
                <div class="col-md-4 mb-3">
                    <label asp-for="VariantPrice" class="form-label">Giá bán</label>
                    <input asp-for="VariantPrice" type="number" class="form-control" />
                    <span asp-validation-for="VariantPrice" class="text-danger"></span>
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="VariantStock" class="form-label">Tồn kho</label>
                    <input asp-for="VariantStock" type="number" class="form-control" />
                    <span asp-validation-for="VariantStock" class="text-danger"></span>
                </div>

                <div class="col-md-4 mb-3">
                    <label asp-for="VariantImageFile" class="form-label">Ảnh biến thể (Tùy chọn)</label>
                    <input asp-for="VariantImageFile" type="file" class="form-control" accept="image/png, image/jpeg" />
                    <span asp-validation-for="VariantImageFile" class="text-danger"></span>
                </div>
            </div>

        </div>

        @* --- FOOTER: Căn lề nút bấm sang phải giống ảnh mẫu --- *@
        <div class="card-footer text-end">
            <a href="@Url.Action("ManageProducts", "Admin")" class="btn btn-secondary">Hủy</a>
            <button type="submit" class="btn btn-primary">Lưu Sản Phẩm</button>
        </div>

    </form>
</div>

@* Thêm một chút CSS để khoảng cách đẹp hơn *@
<style>
    .card-footer {
        display: flex;
        justify-content: flex-end;
        gap: 10px; /* Khoảng cách giữa 2 nút Hủy và Lưu */
    }

    /* Làm cho thông báo lỗi validation nổi bật hơn */
    .text-danger {
        font-size: 0.875em;
        font-weight: 500;
    }
</style>

@* ================================================================== *@
@* === SỬA LỖI Ở ĐÂY: Thêm 2 dòng này để bật Validation phía client === *@
@* ================================================================== *@
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}