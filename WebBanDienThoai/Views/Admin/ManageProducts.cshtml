@model WebBanDienThoai.Models.ViewModels.ManageProductsViewModel

@{
    Layout = "~/Views/Shared/Admin_Layout1.cshtml";
    ViewData["Title"] = "Quản lý Sản phẩm";
}
@* Link tới file CSS riêng của bạn (nếu có) *@
<link href="~/css/Dashboard.css" rel="stylesheet">

<div class="products-container">

    @* --- HEADER (TÌM KIẾM, LỌC, THÊM MỚI) --- *@
    <div class="products-header">
        <form class="product-search-form">
            <input type="text" id="searchId" value="@ViewBag.SearchId" placeholder="Tìm kiếm...">
            <img src="/images/Admin/Product/search_black.png" alt="Search Icon" onclick="filterSearch()">
        </form>
        <div class="products-actions">
            <button class="btn btn-secondary">
                <span>Lọc</span>
                <img src="/images/Admin/Product/admin_filter.png" alt="Filter Icon">
            </button>
            <a href="/Admin/CreateProduct" class="btn btn-primary">
                <span>Thêm</span>
                <img src="/images/Admin/Product/admin_add.png" alt="Add Icon">
            </a>
        </div>
    </div>

    @* --- THANH LỌC THEO HÃNG --- *@
    <nav class="nav nav-pills nav-fill nav-container mb-3">
        @{
            var currentBrandIdStr = ViewContext.RouteData.Values["brandId"]?.ToString();
        }
        <a class="nav-link @(string.IsNullOrEmpty(currentBrandIdStr) ? "active" : "")"
           aria-current="page"
           href="@Url.Action("ManageProducts", "Admin")">
            Tất cả (@Model.TotalProductCount)
        </a>
        @foreach (var brand in Model.BrandCounts)
        {
            <a class="nav-link @(currentBrandIdStr == brand.brandId.ToString() ? "active" : "")"
               href="@Url.Action("ManageProducts", "Admin", new { brandId = brand.brandId })">
                @brand.BrandName (@brand.Count)
            </a>
        }
    </nav>

    @* --- THÔNG BÁO (STATUS MESSAGE) --- *@
    @if (TempData["StatusMessage"] != null)
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            @TempData["StatusMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @* --- BẢNG HIỂN THỊ SẢN PHẨM (ĐÃ CHUYỂN SANG <table>) --- *@
    <div class="table-responsive">
        <table class="table table-hover align-middle product-table-standard">
            <thead class="table-light">
                <tr>
                    <th scope="col" style="width: 35%;">Sản phẩm</th>
                    <th scope="col" style="width: 15%;">Giá</th>
                    <th scope="col" style="width: 10%;">Số lượng</th>
                    <th scope="col" style="width: 10%;">Hãng</th>
                    <th scope="col" style="width: 10%;">Ngày nhập</th>
                    <th scope="col" style="width: 10%;">Trạng thái</th>
                    <th scope="col" style="width: 10%;">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Products != null && Model.Products.Any())
                {
                    @foreach (var item in Model.Products)
                    {
                        <tr>
                            @* 1. Cột Sản phẩm *@
                            <td>
                                <div class="d-flex align-items-center">
                                    @{
                                        string imageUrl = "/images/placeholder.png";
                                        if (!string.IsNullOrEmpty(item.MainImage))
                                        {
                                            imageUrl = item.MainImage.StartsWith("/")
                                            ? item.MainImage : "/" + item.MainImage;
                                        }
                                    }
                                    <div class="product-image me-3">
                                        <img src="@imageUrl" alt="@item.Name" />
                                    </div>
                                    <div class="product-text">
                                        <span class="product-id">ID: @item.ProductId</span>
                                        <span class="product-name">@item.Name</span>
                                    </div>
                                </div>
                            </td>

                            @* 2. Cột Giá *@
                            <td>@String.Format("{0:N0}", item.LowestPrice) vnd</td>

                            @* 3. Cột Số lượng *@
                            <td>@item.TotalStock</td>

                            @* 4. Cột Hãng *@
                            <td>@item.BrandName</td>

                            @* 5. Cột Ngày nhập *@
                            <td>
                                @item.CreatedDate.ToString("dd/MM/yy") <br />
                                <small>@item.CreatedDate.ToString("h:mm tt")</small>
                            </td>

                            @* 6. Cột Trạng thái *@
                            <td>
                                @{
                                    string statusClass = item.IsActive ? "available" : "hidden";
                                    string statusText = item.IsActive ? "Đang bán" : "Đã ẩn";
                                }
                                <span class="status-chip @statusClass">@statusText</span>
                            </td>

                            @* 7. Cột Hành động (CRUD) *@
                            <td>
                                <div class="crud">
                                    @* Nút Xem Chi Tiết *@
                                    <a href="@Url.Action("ProductDetails", "Admin", new { id = item.ProductId })" title="Xem biến thể">
                                        <img src="/images/Admin/Product/view.png" alt="View">
                                    </a>

                                    @* Nút Sửa Nhanh (Kích hoạt Modal) *@
                                    <button type="button"
                                            class="btn-edit"
                                            data-bs-toggle="modal"
                                            data-bs-target="#editProductModal"
                                            data-id="@item.ProductId"
                                            data-name="@item.Name"
                                            data-isactive="@item.IsActive.ToString()"
                                            data-brandid="@item.BrandId"
                                            data-price="@item.LowestPrice.ToString("F0")"
                                            data-stock="@item.TotalStock"
                                            title="Sửa nhanh">
                                        <img src="/images/Admin/Product/edit.png" alt="Edit">
                                    </button>

                                    @* Form Xóa *@
                                    <form asp-action="DeleteProduct" asp-controller="Admin" asp-route-id="@item.ProductId" method="post" onsubmit="return confirm('Bạn chắc chắn muốn xóa sản phẩm này?');">
                                        <button type="submit" class="btn-delete" title="Xóa sản phẩm">
                                            <img src="/images/Admin/Product/delete.png" alt="Delete">
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center p-4">
                            Không có sản phẩm nào được tìm thấy.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @* --- HẾT BẢNG --- *@


    @* --- FOOTER (PHÂN TRANG - Tĩnh) --- *@
    <footer class="products-footer">
        <nav aria-label="Page navigation example" class="ms-auto">
            <ul class="pagination pagination-sm">
                <li class="page-item disabled"><a class="page-link" href="#" aria-label="Previous"><span aria-hidden="true">&laquo;</span></a></li>
                <li class="page-item active"><a class="page-link" href="#">1</a></li>
                <li class="page-item"><a class="page-link" href="#">2</a></li>
                <li class="page-item"><a class="page-link" href="#">3</a></li>
                <li class="page-item"><a class="page-link" href="#" aria-label="Next"><span aria-hidden="true">&raquo;</span></a></li>
            </ul>
        </nav>
    </footer>
</div>

@* ============================================================================== *@
@* ======================== MODAL SỬA NHANH SẢN PHẨM ============================ *@
@* ============================================================================== *@
<div class="modal fade" id="editProductModal" tabindex="-1" aria-labelledby="editProductModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="editProductModalLabel">Sửa Sản Phẩm Nhanh</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            @* --- BẮT ĐẦU FORM SỬA NHANH --- *@
            @* Các thuộc tính "name" RẤT QUAN TRỌNG, phải khớp với tham số Controller *@
            <form id="quickEditForm" method="post" asp-action="QuickEditProduct" asp-controller="Admin">
                @Html.AntiForgeryToken()
                <div class="modal-body">

                    @* Input ẩn chứa ID *@
                    <input type="hidden" id="edit-product-id" name="productId" />

                    @* Tên sản phẩm *@
                    <div class="mb-3">
                        <label for="edit-name" class="form-label">Tên sản phẩm</label>
                        <input type="text" class="form-control" id="edit-name" name="name" required>
                    </div>

                    @* Hãng *@
                    <div class="mb-3">
                        <label for="edit-brand" class="form-label">Hãng</label>
                        <select class="form-select" id="edit-brand" name="brandId" required>
                            @foreach (var brand in Model.BrandCounts)
                            {
                                <option value="@brand.brandId">@brand.BrandName</option>
                            }
                        </select>
                    </div>

                    @* Trạng thái (isActive) - Cần 2 input để binding bool *@
                    <div class="mb-3 form-check">
                        <input type="hidden" name="isActive" value="false" />
                        <input type="checkbox" class="form-check-input" id="edit-is-active" name="isActive" value="true">
                        <label class="form-check-label" for="edit-is-active">Đang bán (Trạng thái)</label>
                    </div>

                    <hr />

                    <div class="alert alert-info p-2 small" role="alert">
                        <strong>CẢNH BÁO:</strong> Giá và Tồn kho sẽ được áp dụng cho <strong>biến thể đầu tiên</strong> của sản phẩm này.
                        <a id="variant-details-link" href="#" class="alert-link small ms-2">👉 Chi tiết Biến thể</a>.
                    </div>

                    <div class="row">
                        @* Giá (lowestPrice) *@
                        <div class="col-md-6 mb-3">
                            <label for="edit-price" class="form-label">Giá (vnd)</label>
                            <input type="number" step="1" min="0" class="form-control"
                                   id="edit-price"
                                   name="lowestPrice"
                                   required>
                        </div>

                        @* Số lượng (totalStock) *@
                        <div class="col-md-6 mb-3">
                            <label for="edit-stock" class="form-label">Số lượng hiện có</label>
                            <input type="number" min="0" class="form-control"
                                   id="edit-stock"
                                   name="totalStock"
                                   required>
                        </div>
                    </div>

                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                    <button type="submit" class="btn btn-primary">Lưu Thay Đổi</button>
                </div>
            </form>
            @* --- HẾT FORM --- *@

        </div>
    </div>
</div>
@* --- HẾT MODAL --- *@


@* ============================================================================== *@
@* ========================== JAVASCRIPT CHO MODAL ============================== *@
@* ============================================================================== *@
<script>
    // Chỉ chạy khi tài liệu đã tải xong
    document.addEventListener('DOMContentLoaded', function () {

        // Lấy element của Modal
        var editProductModal = document.getElementById('editProductModal');

        if (editProductModal) {
            // Lắng nghe sự kiện "sắp mở" của Bootstrap
            editProductModal.addEventListener('show.bs.modal', function (event) {

                // Lấy button đã kích hoạt modal (nút "Sửa")
                var button = event.relatedTarget;

                // Lấy dữ liệu từ các data-attribute của button
                var productId = button.getAttribute('data-id');
                var productName = button.getAttribute('data-name');
                var brandId = button.getAttribute('data-brandid');

                // Chuyển string "True" (từ C#) thành boolean true (cho JS)
                var isActive = button.getAttribute('data-isactive') === 'True';

                var lowestPriceString = button.getAttribute('data-price'); // "500000"
                var totalStock = button.getAttribute('data-stock');

                // Làm sạch giá (loại bỏ mọi dấu chấm/phẩy nếu có)
                var cleanPriceString = lowestPriceString ? lowestPriceString.replace(/,/g, '').replace(/\./g, '') : '0';

                // === ĐÃ SỬA LỖI TYPO TẠI ĐÂY ===
                var lowestPrice = parseInt(cleanPriceString); // Xóa chữ 'a' thừa

                // Lấy các element bên trong form Modal
                var modalTitle = editProductModal.querySelector('.modal-title');
                var modalProductId = editProductModal.querySelector('#edit-product-id');
                var modalProductName = editProductModal.querySelector('#edit-name');
                var modalBrand = editProductModal.querySelector('#edit-brand');
                var modalIsActive = editProductModal.querySelector('#edit-is-active');
                var editPrice = editProductModal.querySelector('#edit-price');
                var editStock = editProductModal.querySelector('#edit-stock');
                var detailsLink = editProductModal.querySelector('#variant-details-link');

                // Gán dữ liệu vào các trường trong form
                modalTitle.textContent = 'Sửa Sản Phẩm Nhanh: ID ' + productId;
                modalProductId.value = productId;
                modalProductName.value = productName;
                modalBrand.value = brandId;

                // Gán trạng thái (boolean) cho checkbox
                modalIsActive.checked = isActive;

                // Gán giá/số lượng
                editPrice.value = lowestPrice;
                editStock.value = totalStock;

                // Cập nhật đường link Chi tiết Biến thể
                if (detailsLink) {
                    detailsLink.href = "/Admin/ProductDetails/" + productId;
                }
            });
        }
    });
        function filterSearch() {
            const searchId = document.getElementById("searchId").value;

            window.location.href = `?searchId=${encodeURIComponent(searchId)}`

        }
</script>
@* --- HẾT JAVASCRIPT --- *@


@* ============================================================================== *@
@* ================================= CSS (STYLE) ================================ *@
@* ============================================================================== *@
<style>
    /* Style cho ảnh sản phẩm trong bảng <table> */
    .product-image {
        flex-shrink: 0;
        width: 60px;
        height: 60px;
        border-radius: 8px;
        overflow: hidden;
        border: 1px solid #eee;
    }

        .product-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    /* Style cho text sản phẩm (Tên, ID) */
    .product-text {
        display: flex;
        flex-direction: column;
    }

    .product-id {
        font-size: 0.8rem;
        color: #6c757d;
        font-family: 'Courier New', Courier, monospace;
    }

    .product-name {
        font-weight: 600;
        color: #333;
    }

    /* Style cho các nút CRUD (Xem, Sửa, Xóa) */
    .crud {
        display: flex;
        align-items: center;
        gap: 8px; /* Khoảng cách giữa các nút */
    }

        .crud form {
            display: inline-block;
            margin: 0;
            padding: 0;
            line-height: 1;
        }

    /* Style chung cho nút Sửa (button) và Xóa (button) */
    .btn-delete, .btn-edit {
        background: none;
        border: none;
        padding: 0;
        cursor: pointer;
        line-height: 1;
    }

    /* Style cho icon trong các nút */
    .crud a img, .crud button img {
        height: 16px;
        width: auto;
        vertical-align: middle;
        opacity: 0.7;
        transition: opacity 0.2s;
    }

    .crud a:hover img, .crud button:hover img {
        opacity: 1;
    }
</style>