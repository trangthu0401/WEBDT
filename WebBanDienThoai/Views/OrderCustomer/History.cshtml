@model IEnumerable<WebBanDienThoai.Models.Order>

@{
    ViewData["Title"] = "Lịch sử mua hàng";
    Layout = "~/Views/Shared/_Layout.cshtml";

    // Giữ trạng thái bộ lọc
    string currentSearch = Context.Request.Query["searchId"];
    string currentStatus = Context.Request.Query["statusFilter"];
    string currentPayment = Context.Request.Query["paymentMethod"].ToString().ToUpper();
    string currentDatePreset = Context.Request.Query["datePreset"];
    string currentStart = Context.Request.Query["startDate"];
    string currentEnd = Context.Request.Query["endDate"];
}

@functions {
    public string GetStatusColor(string status) => status?.ToLower() switch
    {
        "đã giao" or "thành công" or "đã thanh toán" => "success",
        "đang giao" or "vận chuyển" => "info",
        "chờ xử lý" or "chờ xác nhận" => "purple",
        "đã hủy" => "danger",
        _ => "secondary"
    };
}

<style>
    /* CSS trang lịch sử */
    .order-container { background: #fff; min-height: 90vh; padding: 40px 0; font-family: 'Be Vietnam Pro', sans-serif; }
    .filter-wrapper { margin-bottom: 40px; }
    .input-pill-group { position: relative; width: 100%; }
    
    .form-control-pill {
        width: 100%; height: 45px; border: 1px solid #e0e0e0; border-radius: 50px;
        padding-left: 20px; padding-right: 45px; font-size: 0.95rem; outline: none;
        color: #555; background-color: #fff; transition: border-color 0.2s; appearance: none;
    }
    .form-control-pill:focus { border-color: #888; box-shadow: 0 0 0 2px rgba(0,0,0,0.05); }
    .icon-right { position: absolute; right: 15px; top: 50%; transform: translateY(-50%); color: #333; font-size: 1.1rem; pointer-events: none; }
    
    /* Table & Badge */
    .table-card { background: white; border-radius: 12px; overflow: hidden; border: 1px solid #f0f0f0; box-shadow: 0 4px 20px rgba(0,0,0,0.02); }
    .custom-table th { background-color: #fff; padding: 18px 24px; font-size: 0.8rem; font-weight: 700; text-transform: uppercase; color: #999; border-bottom: 1px solid #eee; }
    .custom-table td { padding: 20px 24px; vertical-align: middle; font-size: 0.95rem; border-bottom: 1px solid #f9f9f9; }
    
    .badge-status { padding: 6px 12px; border-radius: 6px; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; }
    .badge-success { background: #e6f9f0; color: #0fa958; }
    .badge-purple { background: #f3e8ff; color: #9333ea; }
    .badge-info { background: #e0f2fe; color: #0284c7; }
    .badge-danger { background: #fee2e2; color: #dc2626; }
    .badge-secondary { background: #f3f4f6; color: #4b5563; }
    .badge-payment { padding: 6px 10px; border-radius: 6px; font-size: 0.75rem; font-weight: 700; border: 1px solid #eee; }
    .pay-cod { background: #fff7ed; color: #c2410c; }
    .pay-qr { background: #eff6ff; color: #1d4ed8; }

    /* Nút Xem Chi Tiết */
    .btn-view-detail {
        width: 35px; height: 35px; border-radius: 50%; background-color: #f8f9fa; color: #666;
        display: inline-flex; align-items: center; justify-content: center; text-decoration: none; transition: 0.2s; border: 1px solid #eee;
    }
    .btn-view-detail:hover { background-color: #e63946; color: white; border-color: #e63946; transform: scale(1.1); }
</style>

<div class="order-container">
    <div class="container">
        
        <!-- Form Bộ Lọc -->
        <form method="get" class="filter-wrapper" id="filterForm" onsubmit="return validateDates(event)">
            <!-- Dòng 1 -->
            <div class="row g-3 mb-4">
                <div class="col-md-5">
                    <div class="input-pill-group">
                        <input type="text" name="searchId" class="form-control-pill" placeholder="Nhập id đơn hàng" value="@currentSearch">
                        <i class="bi bi-search icon-right"></i>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="input-pill-group">
                        <select name="statusFilter" class="form-control-pill" onchange="safeSubmit()">
                            <option value="">--Trạng thái--</option>
                            <option value="Chờ xác nhận" selected="@(currentStatus == "Chờ xác nhận")">Chờ xác nhận</option>
                            <option value="Đang giao" selected="@(currentStatus == "Đang giao")">Đang giao</option>
                            <option value="Đã giao" selected="@(currentStatus == "Đã giao")">Đã giao</option>
                            <option value="Đã hủy" selected="@(currentStatus == "Đã hủy")">Đã hủy</option>
                        </select>
                        <i class="fas fa-caret-down icon-right"></i>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="input-pill-group">
                        <select name="paymentMethod" class="form-control-pill" onchange="safeSubmit()">
                            <option value="">--Thanh toán--</option>
                            <option value="COD" selected="@(currentPayment == "COD")">Tiền mặt (COD)</option>
                            <option value="QR CODE" selected="@(currentPayment == "QR CODE")">Chuyển khoản (QR)</option>
                        </select>
                        <i class="bi bi-credit-card-2-back icon-right"></i>
                    </div>
                </div>
            </div>
            <!-- Dòng 2 -->
            <div class="row g-3 align-items-center">
                <div class="col-md-4">
                    <div class="input-pill-group">
                        <select name="datePreset" class="form-control-pill" onchange="applyDatePreset(this.value)">
                            <option value="">--Chọn theo ngày--</option>
                            <option value="today" selected="@(currentDatePreset == "today")">Hôm nay</option>
                            <option value="7days" selected="@(currentDatePreset == "7days")">7 ngày qua</option>
                            <option value="30days" selected="@(currentDatePreset == "30days")">30 ngày qua</option>
                            <option value="thisMonth" selected="@(currentDatePreset == "thisMonth")">Tháng này</option>
                        </select>
                        <i class="fas fa-caret-down icon-right"></i>
                    </div>
                </div>
                <div class="col-md-4"><input type="date" name="startDate" id="startDate" class="form-control-pill" onchange="safeSubmit()" value="@currentStart"></div>
                <div class="col-md-4"><input type="date" name="endDate" id="endDate" class="form-control-pill" onchange="safeSubmit()" value="@currentEnd"></div>
                <input type="submit" style="display: none;" />
            </div>
        </form>

        <!-- Bảng Dữ Liệu -->
        <div class="table-card">
            <div class="table-responsive">
                <table class="table custom-table mb-0">
                    <thead>
                        <tr>
                            <th class="ps-4">ID</th>
                            <th>TÊN SẢN PHẨM</th>
                            <th class="text-center">THANH TOÁN</th>
                            <th>NGÀY</th>
                            <th class="text-end">TỔNG TIỀN</th>
                            <th class="text-center">TRẠNG THÁI</th>
                            <th class="text-center pe-4">CHI TIẾT</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                string statusClass = GetStatusColor(item.Status);
                                string productName = item.OrderDetails?.FirstOrDefault()?.ProductVariant?.Product?.Name ?? "Sản phẩm";
                                int extraCount = (item.OrderDetails?.Count ?? 0) - 1;
                                string payMethod = item.Payments?.FirstOrDefault()?.PaymentMethod ?? "COD";
                                string payBadge = "pay-cod";
                                if (payMethod.Contains("QR") || payMethod.Contains("Banking")) { payMethod = "QR Code"; payBadge = "pay-qr"; } else { payMethod = "COD"; }

                                <!-- Sự kiện OnClick mở Popup -->
                                <tr style="cursor: pointer;" onclick="openOrderPopup(@item.OrderId)">
                                    <td class="ps-4 text-muted">#@item.OrderId.ToString("D5")</td>
                                    <td class="fw-bold text-dark">@productName @if(extraCount > 0) { <small class="text-muted fw-normal">(+@extraCount khác)</small> }</td>
                                    <td class="text-center"><span class="badge badge-payment @payBadge">@payMethod</span></td>
                                    <td class="text-muted">@item.OrderDate?.ToString("dd/MM/yyyy")</td>
                                    <td class="text-end fw-bold text-danger">@item.TotalAmount?.ToString("N0")₫</td>
                                    <td class="text-center"><span class="badge-status badge-@statusClass">@item.Status</span></td>
                                    <td class="text-center pe-4">
                                        <button type="button" class="btn-view-detail border-0" onclick="event.stopPropagation(); openOrderPopup(@item.OrderId)">
                                            <i class="fas fa-eye"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                        else 
                        {
                            <tr><td colspan="7" class="text-center py-5 text-muted">Không tìm thấy đơn hàng nào.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- 1. MODAL CHI TIẾT (Rỗng, sẽ được nạp dữ liệu bằng AJAX) -->
<div class="modal fade" id="orderDetailModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Chi tiết đơn hàng <span id="modalOrderId" class="text-danger fw-bold"></span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="modalContent">
                <!-- Loading Spinner -->
                <div class="text-center py-5"><div class="spinner-border text-danger"></div></div>
            </div>
            <div class="modal-footer border-0 bg-light">
                <button type="button" class="btn btn-secondary rounded-pill px-4" data-bs-dismiss="modal">Đóng</button>
            </div>
        </div>
    </div>
</div>

<!-- 2. MODAL HỦY ĐƠN -->
<div class="modal fade" id="cancelReasonModal" tabindex="-1" aria-hidden="true" style="z-index: 1060;">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold text-danger">Xác nhận hủy đơn hàng</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="cancelOrderId">
                <div class="d-flex flex-column gap-2">
                    <label class="p-2 border rounded cursor-pointer hover-bg-light">
                        <input type="radio" name="cancelReason" value="Đổi ý không mua nữa" checked class="form-check-input me-2"> Đổi ý không mua nữa
                    </label>
                    <label class="p-2 border rounded cursor-pointer hover-bg-light">
                        <input type="radio" name="cancelReason" value="Tìm thấy nơi khác giá tốt hơn" class="form-check-input me-2"> Tìm thấy giá tốt hơn
                    </label>
                    <label class="p-2 border rounded cursor-pointer hover-bg-light">
                        <input type="radio" name="cancelReason" value="Đặt nhầm sản phẩm" class="form-check-input me-2"> Đặt nhầm sản phẩm
                    </label>
                    <label class="p-2 border rounded cursor-pointer hover-bg-light">
                        <input type="radio" name="cancelReason" value="Khác" class="form-check-input me-2"> Lý do khác
                    </label>
                    <textarea id="otherReason" class="form-control mt-2 d-none" rows="2" placeholder="Nhập lý do..."></textarea>
                </div>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button class="btn btn-secondary rounded-pill px-4" data-bs-dismiss="modal">Bỏ qua</button>
                <button class="btn btn-danger rounded-pill px-4" onclick="submitCancel()">Xác nhận hủy</button>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script>
    // --- 1. Logic Mở Popup Chi Tiết ---
    function openOrderPopup(orderId) {
        var myModal = new bootstrap.Modal(document.getElementById('orderDetailModal'));
        myModal.show();
        
        document.getElementById('modalOrderId').innerText = '#' + String(orderId).padStart(5, '0');
        var contentDiv = document.getElementById('modalContent');
        
        // Reset về loading
        contentDiv.innerHTML = '<div class="text-center py-5"><div class="spinner-border text-danger"></div></div>';
        
        // Gọi AJAX lấy Partial View
        fetch('/OrderCustomer/Details/' + orderId, { 
            headers: { 'X-Requested-With': 'XMLHttpRequest' } 
        })
        .then(r => r.text())
        .then(html => {
            contentDiv.innerHTML = html;
        })
        .catch(err => {
            contentDiv.innerHTML = '<div class="alert alert-danger m-3">Không tải được dữ liệu.</div>';
        });
    }

    // --- 2. Logic Hủy Đơn ---
    function openCancelModal(id) {
        // Đóng popup chi tiết trước
        bootstrap.Modal.getInstance(document.getElementById('orderDetailModal'))?.hide();
        
        $('#cancelOrderId').val(id);
        new bootstrap.Modal(document.getElementById('cancelReasonModal')).show();
    }

    $('input[name="cancelReason"]').change(function() {
        if (this.value === 'Khác') $('#otherReason').removeClass('d-none').focus();
        else $('#otherReason').addClass('d-none');
    });

    function submitCancel() {
        let id = $('#cancelOrderId').val();
        let reason = $('input[name="cancelReason"]:checked').val();
        if (reason === 'Khác') reason = $('#otherReason').val();
        
        if (!reason) { Swal.fire("Lỗi", "Vui lòng nhập lý do", "warning"); return; }
        
        $.post('/OrderCustomer/CancelOrder', { orderId: id, reason: reason }, function(res) {
            if (res.success) {
                Swal.fire("Đã hủy!", res.message, "success").then(() => location.reload());
            } else {
                Swal.fire("Lỗi", res.message, "error");
            }
        });
    }

    // --- 3. Logic Bộ lọc (Giữ nguyên) ---
    function validateDates(e) { /* ...Code cũ... */ return true; }
    function safeSubmit() { document.getElementById('filterForm').submit(); }
    function applyDatePreset(val) { /* ...Code cũ... */ safeSubmit(); }
</script>